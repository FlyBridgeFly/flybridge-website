---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Reset FlyBridge Portal Password",
  description: "Choose a new password after opening your FlyBridge reset link.",
  url: new URL("/reset-password", site.url).toString()
};
---

<BaseLayout
  title="Reset Password"
  description="Choose a new password after opening your FlyBridge reset link."
  path="/reset-password"
  schema={schema}
  noindex={true}
>
  <section class="container-shell pb-8 pt-5 sm:pb-10 sm:pt-6">
    <div class="mx-auto max-w-3xl">
      <form class="form-panel" data-reset-password-form>
        <span class="eyebrow">Password recovery</span>
        <h1 class="mt-4 text-[2rem] font-semibold tracking-tight text-fb-ink sm:text-[2.5rem]">Choose a fresh password.</h1>
        <p class="mt-3 body-copy">
          Use a new password for your FlyBridge portal, then sign in again with the updated details.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="mini-chip">Secure reset</span>
          <span class="mini-chip">Return to portal login</span>
        </div>
        <div class="surface-note mt-4">After saving your new password, sign in again from the portal login with the updated details.</div>
        <div class="form-grid-compact !mt-6 !grid-cols-1">
          <label>
            <span class="label-shell">New password</span>
            <input class="input-shell" name="password" type="password" required autocomplete="new-password" minlength="8" />
          </label>
          <label>
            <span class="label-shell">Confirm new password</span>
            <input class="input-shell" name="confirm-password" type="password" required autocomplete="new-password" minlength="8" />
          </label>
        </div>
        <p class="status-message mt-4 hidden" data-reset-password-feedback role="status" aria-live="polite"></p>
        <div class="form-actions">
          <button class="cta-button w-full sm:w-auto" type="submit">Save new password</button>
          <a class="ghost-button w-full sm:w-auto" href="/login">Back to login</a>
        </div>
      </form>
    </div>
  </section>

  <script>
    import { bootstrapResetPasswordPage, getFriendlyErrorMessage } from "../lib/portal-client";

    bootstrapResetPasswordPage().catch(async (error) => {
      const feedback = document.querySelector("[data-reset-password-feedback]");
      if (feedback instanceof HTMLElement) {
        feedback.classList.remove("hidden");
        feedback.classList.add("status-error");
        feedback.textContent = await getFriendlyErrorMessage(error, "Reset password is not available right now.");
      }
    });
  </script>
</BaseLayout>
