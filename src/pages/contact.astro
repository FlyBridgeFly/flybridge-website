---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactMethods from "../components/ContactMethods.astro";
import FormShell from "../components/FormShell.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact FlyBridge Education",
  description: "Contact FlyBridge Education by WhatsApp, email or enquiry form.",
  url: new URL("/contact", site.url).toString()
};

const fields = [
  { label: "Parent name", name: "parent-name", placeholder: "Your full name", required: true, autocomplete: "name" },
  { label: "Student name", name: "student-name", placeholder: "Student's name" },
  { label: "Email", name: "email", type: "email" as const, placeholder: "you@example.com", required: true, autocomplete: "email" },
  { label: "Phone number", name: "phone", type: "tel" as const, placeholder: "07...", autocomplete: "tel" },
  { label: "Message", name: "message", type: "textarea" as const, placeholder: "Tell us what support you are looking for.", required: true, span: "full" as const }
] as const;

const methods = [
  { label: "WhatsApp", value: site.phone, href: site.whatsappHref, hint: "Quickest route for a fast reply" },
  { label: "Email", value: site.email, href: `mailto:${site.email}`, hint: "Best for a fuller written enquiry" },
  { label: "Book Assessment", value: "Start with a free assessment", href: site.assessmentHref, hint: "Useful if you already know you want subject support" }
] as const;
---

<BaseLayout
  title="Contact"
  description="Contact FlyBridge Education by WhatsApp, email or enquiry form."
  path="/contact"
  schema={schema}
>
  <section class="container-shell section-shell-tight">
    <div class="grid gap-5 lg:grid-cols-[0.86fr_1.14fr]">
      <div class="space-y-4">
        <span class="eyebrow">Contact</span>
        <h1 class="text-balance text-[2rem] font-semibold tracking-tight text-fb-ink sm:text-[2.5rem]">Contact FlyBridge.</h1>
        <p class="max-w-2xl body-copy-compact">Use WhatsApp for speed, email for detail, or the form if you want to send a structured enquiry.</p>
        <ContactMethods methods={methods} />
      </div>
      <FormShell
        title="Contact form"
        body="Submitting opens a pre-filled email draft so your enquiry can be sent immediately."
        fields={fields}
        submitLabel="Send enquiry"
        helper="For the fastest response, WhatsApp remains the quickest route."
        subject="FlyBridge website enquiry"
        recipientEmail={site.email}
        secondaryLabel="WhatsApp FlyBridge"
        secondaryHref={site.whatsappHref}
      />
    </div>
  </section>
</BaseLayout>
