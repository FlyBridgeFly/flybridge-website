---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { aboutSections, site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About FlyBridge Education",
  description:
    "Learn more about the Cambridge-trained background, teaching philosophy and mission behind FlyBridge Education.",
  url: new URL("/about", site.url).toString()
};
---

<BaseLayout
  title="About"
  description="Learn more about FlyBridge Education, including Cambridge training, teaching philosophy, experience and mission."
  path="/about"
  schema={schema}
>
  <PageHero
    eyebrow="About FlyBridge"
    title="A premium science tuition company built on academic depth, clear teaching and genuine care."
    body="FlyBridge was created for families who want more than generic tutoring. The aim is to deliver carefully structured science support that feels credible, calm and effective."
    primaryLabel="Book Free Assessment"
    primaryHref={site.assessmentHref}
    secondaryLabel="Request a Callback"
    secondaryHref={site.callbackHref}
    imageSrc={site.images.bridgeBlueprint}
    imageAlt="A refined bridge blueprint image representing the FlyBridge mission and structure."
    imagePosition="center"
    imageBadge="Built with structure"
  />

  <section class="container-shell section-shell pt-0">
    <SectionHeading
      eyebrow="What shapes the approach"
      title="Why FlyBridge teaches the way it does."
      body="Every part of the experience is designed to help students feel more capable while giving parents confidence that progress is being built with intention."
    />
    <div class="surface-note-sky mt-6">
      FlyBridge is built around two promises at once: students get calm, academically rigorous teaching, and parents get clearer visibility into progress through structured communication and reporting.
    </div>
    <div class="mt-8 grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="image-panel">
        <img
          src={site.images.scienceIcons}
          alt="A refined science-themed image representing specialist GCSE science teaching."
          class="h-full min-h-[240px] w-full object-cover sm:min-h-[280px]"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {aboutSections.map((section) => (
          <article class="card-panel p-5 sm:p-6">
            <h2 class="text-lg font-semibold text-fb-ink sm:text-xl">{section.title}</h2>
            <p class="mt-2 body-copy">{section.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner
    eyebrow="Next step"
    title="If the teaching philosophy feels right, the best next step is a free assessment."
    body="That first conversation helps parents understand how support would be tailored and whether FlyBridge is the right fit."
    actions={[
      { label: "Book Free Assessment", href: site.assessmentHref },
      { label: "Contact FlyBridge", href: site.contactHref, variant: "secondary" }
    ]}
  />
</BaseLayout>
