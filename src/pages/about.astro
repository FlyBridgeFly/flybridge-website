---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About FlyBridge Education",
  description: "Learn more about FlyBridge Education and the educators behind it.",
  url: new URL("/about", site.url).toString()
};

const sections = [
  {
    title: "Founded by educators",
    body: "FlyBridge Education was founded by Mr Mubarak and his mother. Both are science education specialists and both completed teacher training at the University of Cambridge."
  },
  {
    title: "A family-led beginning",
    body: "The company began with a shared commitment to strong science teaching and clearer support for families who wanted more than ad hoc tutoring."
  },
  {
    title: "Qualified teaching",
    body: "Mr Mubarak later completed a Master of Education at Cambridge. That training continues to shape a careful approach to explanation, practice and feedback."
  },
  {
    title: "Carefully selected specialists",
    body: "FlyBridge now works with carefully selected qualified teachers across its subject areas, with an emphasis on experienced classroom practitioners and clear teaching."
  }
] as const;
---

<BaseLayout
  title="About"
  description="Learn more about FlyBridge Education and the educators behind it."
  path="/about"
  schema={schema}
>
  <section class="container-shell section-shell-tight">
    <div class="space-y-4">
      <span class="eyebrow">About FlyBridge</span>
      <h1 class="text-balance text-[2rem] font-semibold tracking-tight text-fb-ink sm:text-[2.6rem] lg:text-[3rem]">A family-led education company built by teachers.</h1>
      <p class="max-w-3xl body-copy-compact">FlyBridge exists to provide clear teaching, subject expertise and better communication for families who want support they can trust.</p>
    </div>
  </section>

  <section class="container-shell section-shell-tight pt-0">
    <div class="grid gap-4 lg:grid-cols-2">
      {sections.map((section) => (
        <article class="dashboard-section">
          <h2 class="text-xl font-semibold tracking-tight text-fb-ink">{section.title}</h2>
          <p class="mt-3 text-sm leading-6 text-fb-ink-soft">{section.body}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
