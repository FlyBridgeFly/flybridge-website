---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import ContactMethods from "../components/ContactMethods.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "FlyBridge Student Hub",
  description: "Access Google Classroom, homework, revision resources and student support links.",
  url: new URL("/student-hub", site.url).toString()
};
---

<BaseLayout
  title="Student Hub"
  description="Access FlyBridge lessons, homework, revision resources and Google Classroom from the Student Hub."
  path="/student-hub"
  schema={schema}
>
  <PageHero
    eyebrow="Student Hub"
    title="Welcome back."
    body="Access your lessons, homework, revision resources and Google Classroom below."
    primaryLabel="Open Google Classroom"
    primaryHref={site.classroomHref}
    secondaryLabel="Need help?"
    secondaryHref={site.contactHref}
    imageSrc={site.images.googleClassroom}
    imageAlt="Google Classroom resources laid out neatly for FlyBridge students."
    imageBadge="Student learning hub"
  />

  <section class="container-shell section-shell pt-0">
    <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr]">
      <div class="space-y-5">
        <span class="eyebrow">Learning access</span>
        <h2 class="text-3xl font-semibold tracking-tight text-fb-ink sm:text-4xl">Everything students need in one organised place.</h2>
        <p class="text-base leading-8 text-fb-ink-soft">
          Google Classroom is the main hub for lesson links, homework, revision resources and feedback. If anything is unclear, support is easy to reach.
        </p>
      </div>
      <div class="card-panel p-8 sm:p-10">
        <div class="grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
          <div class="image-panel">
            <img
              src={site.images.revisionNotebook}
              alt="A revision notebook image representing homework and lesson follow-up."
              class="h-full min-h-[240px] w-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-5">
            <p class="text-xs font-semibold tracking-[0.22em] text-slate-500 uppercase">Lessons</p>
            <p class="mt-3 text-lg font-semibold text-fb-ink">Join live sessions and revisit key materials.</p>
          </div>
          <div class="rounded-[1.5rem] border border-slate-200 bg-white p-5">
            <p class="text-xs font-semibold tracking-[0.22em] text-slate-500 uppercase">Homework</p>
            <p class="mt-3 text-lg font-semibold text-fb-ink">Stay on top of weekly tasks and revision work.</p>
          </div>
        </div>
        <a class="cta-button mt-8 w-full sm:w-auto" href={site.classroomHref} target="_blank" rel="noreferrer">Open Google Classroom</a>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="space-y-5">
      <span class="eyebrow">Need help?</span>
      <h2 class="text-3xl font-semibold tracking-tight text-fb-ink sm:text-4xl">Support is close by if students or parents need assistance.</h2>
      <p class="max-w-2xl text-base leading-8 text-fb-ink-soft">
        If there is an issue with classroom access, homework or lesson information, get in touch directly.
      </p>
    </div>
    <div class="mt-10">
      <ContactMethods />
    </div>
  </section>
</BaseLayout>
