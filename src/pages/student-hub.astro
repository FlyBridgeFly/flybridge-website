---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import ContactMethods from "../components/ContactMethods.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "FlyBridge Student Hub",
  description: "Access Google Classroom, homework, revision resources and student support links.",
  url: new URL("/student-hub", site.url).toString()
};
---

<BaseLayout
  title="Student Hub"
  description="Access FlyBridge lessons, homework, revision resources and Google Classroom from the Student Hub."
  path="/student-hub"
  schema={schema}
>
  <PageHero
    eyebrow="Student Hub"
    title="Welcome back."
    body="Access your lessons, homework, revision resources and Google Classroom below."
    primaryLabel="Open Google Classroom"
    primaryHref={site.classroomHref}
    secondaryLabel="Need help?"
    secondaryHref={site.contactHref}
    imageSrc={site.images.googleClassroom}
    imageAlt="Google Classroom resources laid out neatly for FlyBridge students."
    imageBadge="Student learning hub"
  />

  <section class="container-shell section-shell pt-0">
    <div class="grid gap-5 lg:grid-cols-[0.82fr_1.18fr]">
      <div class="space-y-4">
        <SectionHeading
          eyebrow="Learning access"
          title="Everything students need in one organised place."
          body="Google Classroom is the main hub for lesson links, homework, revision resources and feedback. If anything is unclear, support is easy to reach."
        />
        <div class="surface-note-sky">
          Students use Google Classroom for the working side of tuition. Parents use the FlyBridge Portal for progress summaries, assessment updates and next steps.
        </div>
      </div>
      <div class="card-panel p-4 sm:p-5">
        <div class="grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
          <div class="image-panel">
            <img
              src={site.images.revisionNotebook}
              alt="A revision notebook image representing homework and lesson follow-up."
              class="h-full min-h-[200px] w-full object-cover sm:min-h-[220px]"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="rounded-[1.05rem] border border-slate-200 bg-slate-50 p-4">
            <p class="text-xs font-semibold tracking-[0.22em] text-slate-500 uppercase">Lessons</p>
            <p class="mt-2 text-base font-semibold text-fb-ink sm:text-lg">Join live sessions and revisit key materials.</p>
          </div>
          <div class="rounded-[1.05rem] border border-slate-200 bg-white p-4">
            <p class="text-xs font-semibold tracking-[0.22em] text-slate-500 uppercase">Homework</p>
            <p class="mt-2 text-base font-semibold text-fb-ink sm:text-lg">Stay on top of weekly tasks and revision work.</p>
          </div>
        </div>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          <a class="cta-button w-full" href={site.classroomHref} target="_blank" rel="noreferrer">Open Google Classroom</a>
          <a class="ghost-button w-full" href="/login?portal=parent">Parent Portal</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="space-y-4">
      <SectionHeading
        eyebrow="Need help?"
        title="Support is close by if students or parents need assistance."
        body="If there is an issue with classroom access, homework or lesson information, get in touch directly."
      />
    </div>
    <div class="mt-8">
      <ContactMethods />
    </div>
  </section>
</BaseLayout>
