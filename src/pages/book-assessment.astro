---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { assessmentFeatures, site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Book a Free Assessment",
  description: "Book a free assessment with FlyBridge Education. Placeholder booking structure ready for future calendar integration.",
  url: new URL("/book-assessment", site.url).toString()
};
---

<BaseLayout
  title="Book a Free Assessment"
  description="Book a free assessment with FlyBridge Education. Placeholder booking structure ready for future calendar integration."
  path="/book-assessment"
  schema={schema}
>
  <PageHero
    eyebrow="Book assessment"
    title="A booking page designed to drop into Calendly or Google Calendar later."
    body="For now, the page acts as a polished placeholder with clear next steps so families can still move forward while the final scheduling workflow is connected."
    primaryLabel="WhatsApp to Arrange"
    primaryHref={site.whatsappHref}
    secondaryLabel="Request a Callback"
    secondaryHref={site.callbackHref}
    imageSrc={site.images.assessmentReport}
    imageAlt="A premium assessment report image representing the booking and assessment process."
    imageBadge="Assessment overview"
  />

  <section class="container-shell section-shell pt-0">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="space-y-5">
        <span class="eyebrow">What the assessment covers</span>
        <h2 class="text-3xl font-semibold tracking-tight text-fb-ink sm:text-4xl">The free assessment gives parents clarity before any lessons begin.</h2>
        <div class="grid gap-4">
          {assessmentFeatures.map((item) => (
            <div class="card-panel px-5 py-4 text-base text-fb-ink">{item}</div>
          ))}
        </div>
      </div>
      <div class="card-panel p-8 sm:p-10">
        <p class="text-sm font-semibold tracking-[0.22em] text-slate-500 uppercase">Placeholder booking panel</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight text-fb-ink">Assessment slots will be embedded here.</h2>
        <p class="mt-4 max-w-xl text-base leading-7 text-fb-ink-soft">
          This area is intentionally structured so a Calendly embed, booking iframe or simple calendar integration can replace it later without redesigning the page.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-5">
            <p class="text-xs font-semibold tracking-[0.22em] text-slate-500 uppercase">Fastest route</p>
            <p class="mt-3 text-lg font-semibold text-fb-ink">WhatsApp to arrange an assessment directly</p>
          </div>
          <div class="rounded-[1.5rem] border border-slate-200 bg-white p-5">
            <p class="text-xs font-semibold tracking-[0.22em] text-slate-500 uppercase">Alternative route</p>
            <p class="mt-3 text-lg font-semibold text-fb-ink">Request a callback and discuss the best lesson fit first</p>
          </div>
        </div>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a class="cta-button" href={site.whatsappHref}>WhatsApp</a>
          <a class="ghost-button" href={site.callbackHref}>Request a Callback</a>
        </div>
        <div class="image-panel mt-8">
          <img
            src={site.images.reportCover}
            alt="A premium report cover image representing the clear written guidance parents can expect."
            class="h-[220px] w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <CtaBanner
    eyebrow="Ready when you are"
    title="The assessment is the best first step for understanding what support will actually help."
    body="If you already know you would like to begin, send a message and FlyBridge can help you arrange the next available slot."
    actions={[
      { label: "WhatsApp", href: site.whatsappHref },
      { label: "Email", href: `mailto:${site.email}`, variant: "secondary" }
    ]}
  />
</BaseLayout>
