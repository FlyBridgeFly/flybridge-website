---
import BaseLayout from "../layouts/BaseLayout.astro";
import FormShell from "../components/FormShell.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Book a Free Assessment",
  description: "Book a free assessment with FlyBridge Education.",
  url: new URL("/book-assessment", site.url).toString()
};

const fields = [
  { label: "Parent name", name: "parent-name", placeholder: "Your full name", required: true, autocomplete: "name" },
  { label: "Student name", name: "student-name", placeholder: "Student's name", required: true },
  { label: "Year group", name: "year-group", placeholder: "For example: Year 10", required: true },
  { label: "Email", name: "email", type: "email" as const, placeholder: "you@example.com", required: true, autocomplete: "email" },
  { label: "Phone number", name: "phone", type: "tel" as const, placeholder: "Best number to reach you", autocomplete: "tel" },
  { label: "Preferred assessment time", name: "preferred-time", placeholder: "Weekday evenings, Saturday morning, etc.", required: true },
  { label: "Focus areas", name: "focus-areas", type: "textarea" as const, placeholder: "Share current grades, topics of concern or anything important before the assessment.", span: "full" as const }
] as const;
---

<BaseLayout
  title="Book a Free Assessment"
  description="Book a free assessment with FlyBridge Education."
  path="/book-assessment"
  schema={schema}
>
  <section class="container-shell section-shell-tight">
    <div class="grid gap-5 lg:grid-cols-[0.86fr_1.14fr]">
      <div class="space-y-4">
        <span class="eyebrow">Book assessment</span>
        <h1 class="text-balance text-[2rem] font-semibold tracking-tight text-fb-ink sm:text-[2.5rem]">Book a free assessment.</h1>
        <p class="max-w-2xl body-copy-compact">Use the form to request an assessment slot while calendar integration is still being finalised.</p>
        <div class="dashboard-list">
          <div class="dashboard-list-item">
            <p class="text-sm font-semibold text-fb-ink">What the assessment covers</p>
            <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Current attainment, confidence, exam board, weak areas and the most useful lesson format.</p>
          </div>
          <div class="dashboard-list-item">
            <p class="text-sm font-semibold text-fb-ink">What happens next</p>
            <p class="mt-2 text-sm leading-6 text-fb-ink-soft">FlyBridge reviews the request and follows up using the details and preferred times you provide.</p>
          </div>
        </div>
      </div>
      <FormShell
        title="Assessment request"
        body="Submitting opens a pre-filled email draft so the assessment request can be sent immediately."
        fields={fields}
        submitLabel="Request assessment"
        helper="This placeholder booking flow is structured so Calendly or Google Calendar can replace it later."
        subject="FlyBridge free assessment request"
        recipientEmail={site.email}
        secondaryLabel="WhatsApp FlyBridge"
        secondaryHref={site.whatsappHref}
      />
    </div>
  </section>
</BaseLayout>
