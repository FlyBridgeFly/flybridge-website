---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "How FlyBridge Works",
  description: "Understand the FlyBridge process from free assessment through teaching, follow-up and reporting.",
  url: new URL("/how-it-works", site.url).toString()
};

const steps = [
  {
    title: "Free assessment",
    body: "FlyBridge starts by understanding the pupil’s current position, confidence, curriculum context and the areas causing concern."
  },
  {
    title: "Clear recommendation",
    body: "Parents receive a view on the right subject focus, lesson format and the most useful immediate next step."
  },
  {
    title: "Clear teaching",
    body: "Lessons combine clear explanation, guided practice, independent application and concise follow-up."
  },
  {
    title: "Progress reporting",
    body: "Parents can track lesson summaries, assessments, targets and next steps through the FlyBridge portal."
  }
] as const;
---

<BaseLayout
  title="How It Works"
  description="Understand the FlyBridge process from free assessment through teaching, follow-up and reporting."
  path="/how-it-works"
  schema={schema}
>
  <section class="container-shell section-shell-tight">
    <div class="space-y-4">
      <span class="eyebrow">How it works</span>
      <h1 class="text-balance text-[2rem] font-semibold tracking-tight text-fb-ink sm:text-[2.6rem] lg:text-[3rem]">A clear process from first enquiry to ongoing progress.</h1>
      <p class="max-w-3xl body-copy-compact">FlyBridge is designed to make the next step obvious for both pupils and parents.</p>
    </div>
  </section>

  <section class="container-shell section-shell-tight pt-0">
    <div class="grid gap-4 lg:grid-cols-2">
      {steps.map((step, index) => (
        <article class="dashboard-section">
          <div class="flex items-start gap-4">
            <div class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-fb-bg text-sm font-semibold text-white">{index + 1}</div>
            <div>
              <h2 class="text-xl font-semibold tracking-tight text-fb-ink">{step.title}</h2>
              <p class="mt-3 text-sm leading-6 text-fb-ink-soft">{step.body}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="container-shell section-shell-tight pt-0">
    <div class="dashboard-section">
      <span class="eyebrow">Teaching methodology</span>
      <h2 class="mt-4 text-balance text-[1.8rem] font-semibold tracking-tight text-fb-ink sm:text-[2.2rem]">Learn, practise, apply.</h2>
      <div class="mt-5 grid gap-4 lg:grid-cols-3">
        <div class="dashboard-list-item">
          <p class="text-sm font-semibold text-fb-ink">Learn</p>
          <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Secure the knowledge, vocabulary and methods clearly.</p>
        </div>
        <div class="dashboard-list-item">
          <p class="text-sm font-semibold text-fb-ink">Practise</p>
          <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Build fluency through guided and independent questions.</p>
        </div>
        <div class="dashboard-list-item">
          <p class="text-sm font-semibold text-fb-ink">Apply</p>
          <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Use the knowledge under exam conditions with feedback.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell-tight pt-0">
    <div class="dark-panel p-5 sm:p-6 lg:p-7">
      <div class="grid gap-4 lg:grid-cols-[1fr_0.92fr] lg:items-center">
        <div>
          <span class="eyebrow border-white/15 bg-white/5 text-sky-100">Next step</span>
          <h2 class="mt-4 text-balance text-[1.8rem] font-semibold tracking-tight text-white sm:text-[2.2rem]">Book the assessment and start with clarity.</h2>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          <a class="cta-button justify-center bg-white text-fb-bg hover:bg-sky-50" href={site.assessmentHref}>Book Free Assessment</a>
          <a class="ghost-button justify-center border-white/15 bg-white/5 text-white hover:bg-white/10" href={site.callbackHref}>Request a Callback</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
