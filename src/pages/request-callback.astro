---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import FormShell from "../components/FormShell.astro";
import ContactMethods from "../components/ContactMethods.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Request a Callback",
  description: "Request a callback from FlyBridge Education to discuss GCSE science tuition.",
  url: new URL("/request-callback", site.url).toString()
};

const fields = [
  { label: "Parent name", name: "parent-name", placeholder: "Your full name", required: true, autocomplete: "name" },
  { label: "Student name", name: "student-name", placeholder: "Student's name", required: true },
  { label: "School", name: "school", placeholder: "Current school" },
  { label: "Year group", name: "year-group", placeholder: "For example: Year 10" },
  { label: "Phone number", name: "phone", type: "tel" as const, placeholder: "Best number to call", required: true, autocomplete: "tel" },
  { label: "Email", name: "email", type: "email" as const, placeholder: "you@example.com", required: true, autocomplete: "email" },
  { label: "Preferred callback time", name: "callback-time", placeholder: "After 6pm weekdays, Saturday morning, etc.", required: true },
  { label: "Message", name: "message", type: "textarea" as const, placeholder: "Share any context that would help before the call.", helper: "Include current grades, confidence concerns, or any timetable constraints if helpful." }
] as const;

const callbackMethods = [
  {
    label: "WhatsApp",
    value: site.phone,
    href: site.whatsappHref,
    hint: "Ideal if you want a quick reply first"
  },
  {
    label: "Email",
    value: site.email,
    href: `mailto:${site.email}`,
    hint: "Helpful if you want to give a little more background"
  },
  {
    label: "Book Assessment",
    value: "Prefer to book directly instead",
    href: site.assessmentHref,
    hint: "A good fit if you already know you want the assessment"
  }
] as const;

const trustPoints = [
  {
    title: "Advice before commitment",
    body: "This route is designed for parents who want to talk things through before deciding on lessons."
  },
  {
    title: "Context matters",
    body: "Share the concern briefly and FlyBridge can call back with a clearer understanding of what may help."
  }
] as const;
---

<BaseLayout
  title="Request a Callback"
  description="Request a callback from FlyBridge Education to discuss GCSE science tuition."
  path="/request-callback"
  schema={schema}
>
  <PageHero
    eyebrow="Request a callback"
    title="Prefer a conversation first? Request a callback and we will make the next step feel easy."
    body="This page is designed for parents who want to talk through their child's situation before booking an assessment. Share a few details and FlyBridge can follow up with context in mind."
    primaryLabel="Book Assessment Instead"
    primaryHref={site.assessmentHref}
    secondaryLabel="WhatsApp"
    secondaryHref={site.whatsappHref}
    imageSrc={site.images.workspace}
    imageAlt="A premium workspace image representing thoughtful parent communication."
    imageBadge="Reassuring first conversation"
  />

  <section class="container-shell section-shell pt-0">
    <div class="grid gap-6 lg:grid-cols-[0.82fr_1.18fr]">
      <div class="space-y-4">
        <SectionHeading
          eyebrow="Reassuring first contact"
          title="A callback is a good fit if you want advice before committing."
          body="Many parents simply want to explain what is happening, ask a few practical questions and understand what kind of support would be most effective. That is exactly what this page is for."
        />
        <ContactMethods methods={callbackMethods} />
      </div>
      <FormShell
        title="Callback request"
        body="Complete the fields below and FlyBridge will open a pre-filled email draft so you can send the callback request immediately with the right context."
        fields={fields}
        submitLabel="Request callback"
        helper="Submitting this form opens your email app with the enquiry already written out. If you prefer, you can also WhatsApp FlyBridge directly."
        subject="FlyBridge callback request"
        recipientEmail={site.email}
        secondaryLabel="WhatsApp FlyBridge"
        secondaryHref={site.whatsappHref}
        trustPoints={trustPoints}
      />
    </div>
  </section>
</BaseLayout>
