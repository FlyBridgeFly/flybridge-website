---
import BaseLayout from "../layouts/BaseLayout.astro";
import FormShell from "../components/FormShell.astro";
import ContactMethods from "../components/ContactMethods.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Request a Callback",
  description: "Request a callback from FlyBridge Education to discuss the right subject, level and lesson format.",
  url: new URL("/request-callback", site.url).toString()
};

const fields = [
  { label: "Parent name", name: "parent-name", placeholder: "Your full name", required: true, autocomplete: "name" },
  { label: "Student name", name: "student-name", placeholder: "Student's name", required: true },
  { label: "School", name: "school", placeholder: "Current school" },
  { label: "Year group", name: "year-group", placeholder: "For example: Year 9" },
  { label: "Phone number", name: "phone", type: "tel" as const, placeholder: "Best number to call", required: true, autocomplete: "tel" },
  { label: "Email", name: "email", type: "email" as const, placeholder: "you@example.com", required: true, autocomplete: "email" },
  { label: "Preferred days", name: "preferred-days", placeholder: "Weekdays, Saturdays, or specific days", required: true },
  { label: "Preferred hours", name: "preferred-hours", placeholder: "After 5pm, mornings, early evenings", required: true },
  {
    label: "Optional message",
    name: "message",
    type: "textarea" as const,
    placeholder: "Share subject, confidence, attainment or timetable context if helpful.",
    span: "full" as const
  }
] as const;

const methods = [
  { label: "WhatsApp", value: site.phone, href: site.whatsappHref, hint: "Quickest route for a fast reply" },
  { label: "Email", value: site.email, href: `mailto:${site.email}`, hint: "Useful if you want to give fuller context" },
  { label: "Book Assessment", value: "Prefer to book directly", href: site.assessmentHref, hint: "Best if you already know the next step" }
] as const;
---

<BaseLayout
  title="Request a Callback"
  description="Request a callback from FlyBridge Education to discuss the right subject, level and lesson format."
  path="/request-callback"
  schema={schema}
>
  <section class="container-shell section-shell-tight">
    <div class="grid gap-5 lg:grid-cols-[0.86fr_1.14fr]">
      <div class="space-y-4">
        <span class="eyebrow">Request a callback</span>
        <h1 class="text-balance text-[2rem] font-semibold tracking-tight text-fb-ink sm:text-[2.5rem]">Talk through the right next step.</h1>
        <p class="max-w-2xl body-copy-compact">Use this route if you want to discuss subject choice, key stage, lesson format or availability before booking.</p>
        <ContactMethods methods={methods} />
      </div>
      <FormShell
        title="Callback request"
        body="Share the essentials and FlyBridge will open a pre-filled email draft with the right context."
        fields={fields}
        submitLabel="Request callback"
        helper="This keeps the site static while still giving you a real submission route."
        subject="FlyBridge callback request"
        recipientEmail={site.email}
        secondaryLabel="WhatsApp FlyBridge"
        secondaryHref={site.whatsappHref}
      />
    </div>
  </section>
</BaseLayout>
