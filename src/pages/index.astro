---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroIllustration from "../components/HeroIllustration.astro";
import SubjectIcon from "../components/SubjectIcon.astro";
import {
  faqs,
  flybridgeHighlights,
  site,
  steps,
  subjects,
  trustItems
} from "../data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: site.url,
    description: site.description
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
      "@type": "Question",
      name: faq.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.answer
      }
    }))
  }
];
---

<BaseLayout
  title="Cambridge-trained GCSE Science Tuition"
  description={site.description}
  path="/"
  schema={schema}
>
  <section class="container-shell pb-16 pt-10 sm:pb-20 sm:pt-14">
    <div class="grid items-center gap-14 lg:grid-cols-[1.02fr_0.98fr]">
      <div class="space-y-8">
        <span class="eyebrow">Premium online GCSE science tuition</span>
        <div class="space-y-6">
          <h1 class="max-w-3xl text-balance text-5xl font-semibold tracking-tight text-fb-ink sm:text-6xl lg:text-7xl">
            Cambridge-trained GCSE Science Tuition
          </h1>
          <p class="max-w-2xl text-balance text-lg leading-8 text-fb-ink-soft sm:text-xl">
            Helping students bridge the gap to Grades 7-9 with engaging online science tuition, personalised support and structured progress tracking.
          </p>
        </div>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a class="cta-button" href="#contact">Book Free Assessment</a>
          <a class="ghost-button" href="/student-hub">Student Hub</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-3">
          <div class="rounded-[1.5rem] border border-white/70 bg-white/70 p-5 shadow-lg shadow-slate-200/50">
            <p class="text-3xl font-semibold text-fb-ink">7-9</p>
            <p class="mt-2 text-sm text-fb-ink-soft">A focused pathway for ambitious GCSE outcomes.</p>
          </div>
          <div class="rounded-[1.5rem] border border-white/70 bg-white/70 p-5 shadow-lg shadow-slate-200/50">
            <p class="text-3xl font-semibold text-fb-ink">Online</p>
            <p class="mt-2 text-sm text-fb-ink-soft">Structured live lessons built around clarity and accountability.</p>
          </div>
          <div class="rounded-[1.5rem] border border-white/70 bg-white/70 p-5 shadow-lg shadow-slate-200/50">
            <p class="text-3xl font-semibold text-fb-ink">Tracked</p>
            <p class="mt-2 text-sm text-fb-ink-soft">Homework, feedback and revision resources in one place.</p>
          </div>
        </div>
      </div>
      <HeroIllustration />
    </div>
  </section>

  <section class="container-shell section-shell pt-0">
    <div class="card-panel p-8 sm:p-10">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl space-y-3">
          <span class="eyebrow">Trusted foundations</span>
          <h2 class="text-3xl font-semibold tracking-tight text-fb-ink sm:text-4xl">Built for students who want premium support, not generic tutoring.</h2>
        </div>
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {trustItems.map((item) => (
          <div class="rounded-[1.5rem] border border-slate-200/80 bg-white/80 p-5">
            <div class="flex items-start gap-4">
              <span class="mt-1 grid h-9 w-9 shrink-0 place-items-center rounded-xl bg-sky-100 text-sky-700">
                <svg viewBox="0 0 20 20" class="h-4 w-4" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.42l-7.2 7.2a1 1 0 01-1.415 0l-3.2-3.2a1 1 0 011.414-1.415l2.493 2.492 6.493-6.492a1 1 0 011.415-.005z" clip-rule="evenodd"></path>
                </svg>
              </span>
              <p class="text-base font-medium text-fb-ink">{item}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="how-it-works" class="container-shell section-shell">
    <div class="grid gap-10 lg:grid-cols-[0.78fr_1.22fr]">
      <div class="space-y-5">
        <span class="eyebrow">How it works</span>
        <h2 class="text-3xl font-semibold tracking-tight text-fb-ink sm:text-4xl">A calm, structured journey from first conversation to measurable progress.</h2>
        <p class="max-w-xl text-lg leading-8 text-fb-ink-soft">
          Every part of the experience is designed to reduce overwhelm, build momentum and keep students moving with clarity.
        </p>
      </div>
      <div class="space-y-5">
        {steps.map((step, index) => (
          <div class="card-panel relative p-6 sm:p-7">
            {index !== steps.length - 1 && (
              <div class="absolute left-12 top-18 h-[calc(100%-2.25rem)] w-px bg-slate-200"></div>
            )}
            <div class="flex gap-5">
              <div class="grid h-12 w-12 shrink-0 place-items-center rounded-2xl bg-fb-bg text-sm font-semibold text-white">
                {index + 1}
              </div>
              <div>
                <h3 class="text-xl font-semibold text-fb-ink">{step.title}</h3>
                <p class="mt-3 text-base leading-7 text-fb-ink-soft">{step.body}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="courses" class="container-shell section-shell">
    <div class="space-y-5">
      <span class="eyebrow">Subjects</span>
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <h2 class="text-3xl font-semibold tracking-tight text-fb-ink sm:text-4xl">Subject support designed around rigour, confidence and exam success.</h2>
        </div>
        <p class="max-w-xl text-base leading-7 text-fb-ink-soft">
          Each course area is taught with structured explanations, retrieval practice and clear links to GCSE exam performance.
        </p>
      </div>
    </div>
    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {subjects.map((subject) => (
        <article class="card-panel p-7 transition duration-300 hover:-translate-y-1">
          <div class="flex items-start gap-5">
            <SubjectIcon subject={subject.name} />
            <div>
              <h3 class="text-2xl font-semibold text-fb-ink">{subject.name}</h3>
              <p class="mt-3 text-base leading-7 text-fb-ink-soft">{subject.summary}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="dark-panel section-grid relative overflow-hidden p-8 sm:p-10 lg:p-14">
      <div class="absolute right-0 top-0 h-48 w-48 -translate-y-12 translate-x-12 rounded-full bg-sky-400/20 blur-3xl"></div>
      <div class="relative grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="space-y-5">
          <span class="eyebrow border-white/15 bg-white/5 text-sky-100">Why FlyBridge</span>
          <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Premium support for students who need more than just extra worksheets.</h2>
          <p class="max-w-xl text-lg leading-8 text-slate-300">
            FlyBridge blends academic depth, careful structure and personalised guidance so students know exactly what to improve and how to improve it.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {flybridgeHighlights.map((item) => (
            <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 backdrop-blur">
              <p class="text-lg font-medium text-white">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div class="space-y-5">
        <span class="eyebrow">Pricing</span>
        <h2 class="text-3xl font-semibold tracking-tight text-fb-ink sm:text-4xl">Simple, elegant pricing with room for the right fit.</h2>
        <p class="max-w-xl text-lg leading-8 text-fb-ink-soft">
          Start with a free assessment so we can recommend the best support format before lessons begin.
        </p>
      </div>
      <div class="card-panel p-8 sm:p-10">
        <p class="text-sm font-semibold tracking-[0.22em] text-slate-500 uppercase">Starting from</p>
        <div class="mt-4 flex items-end gap-2">
          <span class="text-5xl font-semibold tracking-tight text-fb-ink">£20</span>
          <span class="pb-2 text-lg text-fb-ink-soft">/hour</span>
        </div>
        <div class="mt-8 grid gap-3 text-base text-fb-ink">
          <p>Free assessment</p>
          <p>Flexible scheduling</p>
          <p>Online lessons</p>
          <p>Small groups</p>
        </div>
        <a class="cta-button mt-8" href="#contact">Book Free Assessment</a>
        <p class="mt-5 text-sm leading-6 text-fb-ink-soft">
          Final tuition fees may vary depending on year group, lesson format and availability.
        </p>
      </div>
    </div>
  </section>

  <section id="faqs" class="container-shell section-shell">
    <div class="space-y-5">
      <span class="eyebrow">FAQs</span>
      <h2 class="max-w-2xl text-3xl font-semibold tracking-tight text-fb-ink sm:text-4xl">Clear answers for families who want confidence before getting started.</h2>
    </div>
    <div class="mt-10 space-y-4">
      {faqs.map((faq) => (
        <details class="card-panel group p-6">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-lg font-semibold text-fb-ink">
            {faq.question}
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-slate-100 text-slate-500 transition group-open:rotate-45">
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="currentColor" aria-hidden="true">
                <path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z"></path>
              </svg>
            </span>
          </summary>
          <p class="mt-4 max-w-3xl text-base leading-7 text-fb-ink-soft">{faq.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <section id="contact" class="container-shell section-shell">
    <div class="dark-panel relative overflow-hidden p-8 sm:p-10 lg:p-14">
      <div class="absolute inset-y-0 right-0 hidden w-1/2 bg-[radial-gradient(circle_at_top,rgba(77,162,255,0.28),transparent_55%)] lg:block"></div>
      <div class="relative grid gap-10 lg:grid-cols-[1fr_0.9fr] lg:items-center">
        <div class="space-y-5">
          <span class="eyebrow border-white/15 bg-white/5 text-sky-100">Contact</span>
          <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Book a Free Assessment</h2>
          <p class="max-w-xl text-lg leading-8 text-slate-300">
            Start with a conversation about your child's goals, current performance and the kind of support that would help most.
          </p>
        </div>
        <div class="rounded-[2rem] border border-white/10 bg-white/[0.06] p-7 backdrop-blur">
          <div class="space-y-5">
            <div>
              <p class="text-xs font-semibold tracking-[0.22em] text-sky-100 uppercase">WhatsApp</p>
              <a class="mt-2 inline-block text-2xl font-semibold text-white" href={site.whatsappHref} target="_blank" rel="noreferrer">{site.phone}</a>
            </div>
            <div>
              <p class="text-xs font-semibold tracking-[0.22em] text-sky-100 uppercase">Email</p>
              <a class="mt-2 inline-block text-lg font-semibold text-white" href={`mailto:${site.email}`}>{site.email}</a>
            </div>
            <a class="cta-button mt-2 w-full bg-white text-fb-bg hover:bg-sky-50" href={site.whatsappHref}>Book Assessment</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
