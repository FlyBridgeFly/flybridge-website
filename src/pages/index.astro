---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SubjectOverviewCard from "../components/SubjectOverviewCard.astro";
import PricingCard from "../components/PricingCard.astro";
import FAQList from "../components/FAQList.astro";
import CtaBanner from "../components/CtaBanner.astro";
import {
  assessmentFeatures,
  faqs,
  flybridgeMethod,
  heroSupportPoints,
  heroMetrics,
  lessonFlow,
  parentReasons,
  parentPortalFeatures,
  platformSplit,
  pricingFeatures,
  progressTracking,
  site,
  subjectPages,
  tutorHighlights
} from "../data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: site.url,
    description: site.description
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "GCSE science tuition",
    provider: {
      "@type": "EducationalOrganization",
      name: site.name,
      url: site.url
    },
    areaServed: "United Kingdom",
    description: site.description
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
      "@type": "Question",
      name: faq.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.answer
      }
    }))
  }
];
---

<BaseLayout
  title="Cambridge-trained GCSE Science Tuition"
  description={site.description}
  path="/"
  schema={schema}
>
  <PageHero
    eyebrow="Premium online GCSE science tuition"
    title="Cambridge-trained GCSE Science tuition with free assessment and clear parent reporting."
    body="FlyBridge helps students bridge the gap to Grades 7-9 through thoughtful online teaching, Google Classroom delivery and a premium reporting portal that keeps parents informed after every lesson."
    primaryLabel="Book Free Assessment"
    primaryHref={site.assessmentHref}
    secondaryLabel="Request a Callback"
    secondaryHref={site.callbackHref}
    tertiaryLabel="Student Hub"
    tertiaryHref="/student-hub"
    imageSrc={site.images.heroStudyDesk}
    imageAlt="A premium study desk setup representing focused GCSE science tuition."
    imageLoading="eager"
    imagePosition="center"
    imageBadge="Cambridge-trained support"
    supportPoints={heroSupportPoints}
  />

  <section class="container-shell section-shell-tight pt-0">
    <div class="grid gap-4 md:grid-cols-3">
      {heroMetrics.map((item) => (
        <div class="card-panel p-4 sm:p-5">
          <p class="text-2xl font-semibold text-fb-ink sm:text-[1.8rem]">{item.value}</p>
          <p class="mt-2 text-sm leading-6 text-fb-ink-soft">{item.label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
      <div class="space-y-5">
        <SectionHeading
          eyebrow="Parent reporting"
          title="Clear updates after every lesson."
          body="FlyBridge does not leave families guessing. Parents can follow what was covered, how the student responded, what needs attention next and how assessment performance is moving over time."
        />
        <div class="surface-note-sky">
          Google Classroom is used for learning materials and homework. The FlyBridge Portal is the parent-facing progress layer, designed for calm visibility rather than extra noise.
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          {platformSplit.map((item) => (
            <div class="card-panel p-5">
              <h3 class="text-base font-semibold text-fb-ink sm:text-lg">{item.title}</h3>
              <p class="mt-2 body-copy-compact">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="grid gap-4 lg:grid-cols-[0.92fr_1.08fr]">
        <div class="image-panel">
          <img
            src={site.images.reportCover}
            alt="A premium parent reporting dashboard visual representing post-lesson updates."
            class="h-full min-h-[240px] w-full object-cover sm:min-h-[260px]"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          {parentPortalFeatures.map((item) => (
            <div class="card-panel px-4 py-4 text-sm leading-6 text-fb-ink-soft">
              <span class="mini-chip">Portal view</span>
              <p class="mt-3 text-sm font-semibold text-fb-ink sm:text-base">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell pt-0">
    <SectionHeading
      eyebrow="Why parents choose FlyBridge"
      title="A premium tuition experience designed to feel thoughtful, organised and genuinely effective."
      body="Parents are not just looking for extra lessons. They want credible teaching, steady communication and a clear path from concern to progress."
    />
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      {parentReasons.map((item) => (
        <div class="card-panel p-5 sm:p-6">
          <h3 class="text-lg font-semibold text-fb-ink sm:text-xl">{item.title}</h3>
          <p class="mt-3 body-copy">{item.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="grid gap-6 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
      <SectionHeading
        eyebrow="Meet your tutor"
        title="Academic depth, GCSE focus and a calm teaching style that helps students engage."
        body="FlyBridge is built around the idea that students learn best when teaching is both rigorous and reassuring. High standards matter, but so does the way they are delivered."
      />
      <div class="card-panel p-5 sm:p-6">
        <div class="grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
          <div class="image-panel">
            <img
              src={site.images.bridgeBlueprint}
              alt="A premium bridge blueprint visual representing the FlyBridge mission and structure."
              class="h-full min-h-[220px] w-full object-cover sm:min-h-[240px]"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="grid gap-5 sm:grid-cols-3 lg:grid-cols-1">
            {tutorHighlights.map((item) => (
              <div class="rounded-[1.15rem] border border-slate-200 bg-slate-50/80 p-4">
                <h3 class="text-base font-semibold text-fb-ink sm:text-lg">{item.title}</h3>
                <p class="mt-2 text-sm leading-6 text-fb-ink-soft">{item.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="dark-panel section-grid relative overflow-hidden p-6 sm:p-8 lg:p-10">
      <div class="absolute right-0 top-0 h-48 w-48 -translate-y-12 translate-x-12 rounded-full bg-sky-400/20 blur-3xl"></div>
      <div class="relative">
        <SectionHeading
          eyebrow="The FlyBridge method"
          title="A simple, premium process that gives families clarity from the first conversation."
          body="The goal is to reduce uncertainty. Parents understand what the student needs, students know what to work on, and lessons stay focused."
        />
        <div class="mt-6 grid gap-4 md:grid-cols-[1.1fr_0.9fr] xl:grid-cols-[1.2fr_0.8fr]">
          <div class="image-panel order-2 md:order-1">
            <img
              src={site.images.learningPath}
              alt="A structured learning path visual representing the FlyBridge teaching method."
              class="h-full min-h-[250px] w-full object-cover sm:min-h-[280px]"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="order-1 grid gap-5 md:order-2 md:grid-cols-2">
            {flybridgeMethod.map((item) => (
              <div class="rounded-[1.25rem] border border-white/10 bg-white/[0.05] p-5 backdrop-blur">
                <h3 class="text-lg font-semibold text-white">{item.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-300">{item.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell">
    <SectionHeading
      eyebrow="Subjects"
      title="Dedicated support across GCSE science."
      body="Each subject page explains what is covered, how online lessons are structured and how FlyBridge approaches progress."
    />
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      {subjectPages.map((subject) => <SubjectOverviewCard subject={subject} />)}
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr]">
      <SectionHeading
        eyebrow="How lessons work"
        title="Structured weekly tuition with clear expectations and no wasted time."
        body="The lesson experience is built for busy families who want consistency, quality and a strong sense of direction."
      />
      <div class="space-y-4">
        {lessonFlow.map((item, index) => (
          <div class="card-panel relative p-5 sm:p-6">
            {index !== lessonFlow.length - 1 && <div class="absolute left-10 top-[4.1rem] h-[calc(100%-2rem)] w-px bg-slate-200"></div>}
            <div class="flex gap-4">
              <div class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-fb-bg text-sm font-semibold text-white">{index + 1}</div>
              <div>
                <h3 class="text-lg font-semibold text-fb-ink sm:text-xl">{item.title}</h3>
                <p class="mt-2 body-copy">{item.body}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
      <SectionHeading
        eyebrow="Progress tracking"
        title="Parents can see how support is translating into real progress."
        body="FlyBridge is designed to feel transparent. Materials, homework, revision guidance and feedback are organised so improvement is easier to spot and sustain."
      />
      <div class="grid gap-4 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="image-panel">
          <img
            src={site.images.progressDashboard}
            alt="A progress dashboard visual representing tracked GCSE science progress."
            class="h-full min-h-[240px] w-full object-cover sm:min-h-[260px]"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {progressTracking.map((item) => (
            <div class="card-panel px-4 py-4 text-sm leading-6 text-fb-ink sm:text-base">{item}</div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <SectionHeading
        eyebrow="Pricing"
        title="Straightforward pricing with the free assessment built in."
        body="Start with an assessment so recommendations are based on the student's actual needs rather than a generic package."
      />
      <PricingCard
        price="£20"
        ctaLabel="Book Free Assessment"
        ctaHref={site.assessmentHref}
        features={pricingFeatures}
        note="Final tuition fees may vary depending on year group, lesson format and availability."
      />
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="grid gap-6 lg:grid-cols-[0.88fr_1.12fr] lg:items-center">
      <SectionHeading
        eyebrow="Free assessment"
        title="A calm first step for parents who want clarity before committing."
        body="The assessment is designed to be genuinely useful. It helps identify where the student is now, what is holding them back and what support would make the biggest difference."
      />
      <div class="grid gap-4 lg:grid-cols-[1fr_0.9fr]">
        <div class="grid gap-4 sm:grid-cols-2">
          {assessmentFeatures.map((item) => (
            <div class="card-panel px-4 py-4 text-sm leading-6 text-fb-ink sm:text-base">{item}</div>
          ))}
        </div>
        <div class="image-panel">
          <img
            src={site.images.assessmentReport}
            alt="An assessment report visual representing FlyBridge's free assessment and reporting process."
            class="h-full min-h-[240px] w-full object-cover sm:min-h-[260px]"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <SectionHeading
        eyebrow="FAQ preview"
        title="A few of the questions parents usually ask first."
        body="Detailed answers are available on the full FAQs page."
      />
      <a class="ghost-button" href="/faqs">View all FAQs</a>
    </div>
    <div class="mt-6">
      <FAQList items={faqs.slice(0, 4)} />
    </div>
  </section>

  <CtaBanner
    eyebrow="Get started"
    title="Book a free assessment and take the uncertainty out of GCSE science support."
    body="Whether your child needs stronger foundations, sharper exam technique or a more consistent approach to revision, FlyBridge can help you map the next step."
    actions={[
      { label: "Book Free Assessment", href: site.assessmentHref },
      { label: "Request a Callback", href: site.callbackHref, variant: "secondary" },
      { label: "WhatsApp", href: site.whatsappHref, variant: "secondary" },
      { label: "Email", href: `mailto:${site.email}`, variant: "secondary" }
    ]}
  />
</BaseLayout>
