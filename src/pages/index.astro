---
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQList from "../components/FAQList.astro";
import PricingCard from "../components/PricingCard.astro";
import { faqs, pricingFeatures, site } from "../data/site";
import { keyStageLandingPages } from "../data/curriculum";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: site.url,
    description: site.description
  },
  {
    "@context": "https://schema.org",
    "@type": "EducationalOrganization",
    name: site.name,
    url: site.url,
    description: site.description
  }
];

const homepageFaqs = faqs.slice(0, 5);
---

<BaseLayout
  title="Qualified-Teacher Tuition With Clear Parent Reporting"
  description={site.description}
  path="/"
  schema={schema}
>
  <section class="container-shell section-shell-tight">
    <div class="grid gap-6 lg:grid-cols-[1.08fr_0.92fr] lg:items-center">
      <div class="space-y-5">
        <span class="eyebrow">FlyBridge Education</span>
        <div class="space-y-3">
          <h1 class="text-balance text-[2.15rem] font-semibold tracking-tight text-fb-ink sm:text-[2.8rem] lg:text-[3.3rem]">
            Qualified teachers. Clear teaching. Parent reporting.
          </h1>
          <p class="max-w-3xl body-copy-compact">
            FlyBridge Education helps pupils move forward through organised teaching, curriculum-aware support and reporting that makes progress easy to follow.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a class="cta-button w-full sm:w-auto" href={site.assessmentHref}>Book Free Assessment</a>
          <a class="ghost-button w-full sm:w-auto" href={site.callbackHref}>Request a Callback</a>
          <a class="ghost-button w-full sm:w-auto" href="/student-hub">Student Hub</a>
        </div>
        <div class="grid gap-3 sm:grid-cols-3">
          <div class="dashboard-list-item">
            <p class="text-xs font-semibold tracking-[0.14em] text-slate-500 uppercase">Founded by educators</p>
            <p class="mt-2 text-sm text-fb-ink-soft">Founded by Mr Mubarak and his mother.</p>
          </div>
          <div class="dashboard-list-item">
            <p class="text-xs font-semibold tracking-[0.14em] text-slate-500 uppercase">Qualified teaching</p>
            <p class="mt-2 text-sm text-fb-ink-soft">Cambridge teacher training and careful classroom practice.</p>
          </div>
          <div class="dashboard-list-item">
            <p class="text-xs font-semibold tracking-[0.14em] text-slate-500 uppercase">Clear parent reporting</p>
            <p class="mt-2 text-sm text-fb-ink-soft">Lesson updates, targets and assessments in one portal.</p>
          </div>
        </div>
      </div>
      <div class="dashboard-section hero-glow">
        <div class="grid gap-3">
          {keyStageLandingPages.map((stage) => (
            <a class="dashboard-list-item transition hover:border-slate-300 hover:bg-white" href={`/${stage.slug}`}>
              <div class="flex items-center justify-between gap-3">
                <div>
                  <p class="text-xs font-semibold tracking-[0.16em] text-slate-500 uppercase">{stage.keyStage}</p>
                  <p class="mt-1 text-base font-semibold text-fb-ink">{stage.title}</p>
                </div>
                <span class="mini-chip">{stage.subjects.length} subjects</span>
              </div>
              <p class="mt-2 text-sm leading-6 text-fb-ink-soft">{stage.summary}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell-tight pt-0">
    <div class="dashboard-metric-grid">
      <div class="dashboard-section">
        <p class="text-sm font-semibold text-fb-ink">Why FlyBridge</p>
        <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Qualified classroom practitioners, clear teaching and straightforward communication with families.</p>
      </div>
      <div class="dashboard-section">
        <p class="text-sm font-semibold text-fb-ink">How tuition works</p>
        <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Assessment first, planned teaching, guided practice and concise reporting after progress checkpoints.</p>
      </div>
      <div class="dashboard-section">
        <p class="text-sm font-semibold text-fb-ink">What parents see</p>
        <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Latest lesson, current targets, assessment movement and follow-up tasks without extra noise.</p>
      </div>
      <div class="dashboard-section">
        <p class="text-sm font-semibold text-fb-ink">Who teaches</p>
        <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Carefully selected qualified teachers and experienced subject specialists across FlyBridge subjects.</p>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell-tight pt-0">
    <div class="dashboard-section">
      <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <span class="eyebrow">Qualified teachers</span>
          <h2 class="mt-4 text-balance text-[1.8rem] font-semibold tracking-tight text-fb-ink sm:text-[2.2rem]">Qualified teachers, not generic tutoring</h2>
          <p class="mt-3 body-copy-compact">
            FlyBridge tuition is delivered by qualified teachers who understand how pupils learn, where misconceptions develop and how to turn explanation into independent performance.
          </p>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          {[
            "Curriculum expertise",
            "Misconception diagnosis",
            "Clear teacher modelling",
            "Guided and independent practice",
            "Assessment-informed planning",
            "Exam-board familiarity",
            "Safeguarding and professional standards"
          ].map((item) => (
            <div class="dashboard-list-item text-sm font-medium text-fb-ink">{item}</div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell-tight pt-0">
    <div class="dashboard-section">
      <span class="eyebrow">Teaching methodology</span>
      <h2 class="mt-4 text-balance text-[1.8rem] font-semibold tracking-tight text-fb-ink sm:text-[2.2rem]">A teaching method built for lasting progress</h2>
      <div class="mt-6 grid gap-4 lg:grid-cols-3">
        {[
          ["Learn", "Secure the knowledge, vocabulary and methods clearly."],
          ["Practise", "Build fluency through guided and independent questions."],
          ["Apply", "Use the knowledge under exam conditions with feedback."]
        ].map(([title, body], index) => (
          <div class="relative">
            <div class="flex items-center gap-3">
              <div class="grid h-11 w-11 place-items-center rounded-full bg-fb-bg text-sm font-semibold text-white">{index + 1}</div>
              <div class="h-px flex-1 bg-slate-200 lg:block hidden"></div>
            </div>
            <div class="mt-4 space-y-2">
              <h3 class="text-lg font-semibold text-fb-ink">{title}</h3>
              <p class="text-sm leading-6 text-fb-ink-soft">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container-shell section-shell-tight pt-0">
    <div class="grid gap-4 lg:grid-cols-[1fr_0.95fr]">
      <div class="dashboard-section">
        <span class="eyebrow">Parent reporting</span>
        <h2 class="mt-4 text-balance text-[1.8rem] font-semibold tracking-tight text-fb-ink sm:text-[2.2rem]">Parent reporting is built into the service.</h2>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          {[
            "Latest lesson summary",
            "Homework and next step",
            "Active targets",
            "Assessment movement",
            "Progress status",
            "Google Classroom access"
          ].map((item) => (
            <div class="dashboard-list-item text-sm font-medium text-fb-ink">{item}</div>
          ))}
        </div>
      </div>
      <PricingCard
        price="£20"
        ctaLabel="Book Free Assessment"
        ctaHref={site.assessmentHref}
        features={pricingFeatures}
        note="Final tuition fees may vary depending on year group, lesson format and availability."
      />
    </div>
  </section>

  <section class="container-shell section-shell-tight pt-0">
    <div class="grid gap-5 lg:grid-cols-[0.88fr_1.12fr]">
      <div class="space-y-4">
        <span class="eyebrow">How to start</span>
        <h2 class="text-balance text-[1.8rem] font-semibold tracking-tight text-fb-ink sm:text-[2.2rem]">Start with a free assessment.</h2>
        <div class="dashboard-list">
          <div class="dashboard-list-item">
            <p class="text-sm font-semibold text-fb-ink">1. Share the current picture</p>
            <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Year group, subject, exam board, confidence and the areas causing concern.</p>
          </div>
          <div class="dashboard-list-item">
            <p class="text-sm font-semibold text-fb-ink">2. Receive a recommendation</p>
            <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Lesson format, likely focus and the most useful next step for the pupil.</p>
          </div>
          <div class="dashboard-list-item">
            <p class="text-sm font-semibold text-fb-ink">3. Begin ongoing support</p>
            <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Teaching, follow-up tasks and parent updates begin from a clear plan.</p>
          </div>
        </div>
      </div>
      <div class="dashboard-section">
        <span class="eyebrow">FAQs</span>
        <h2 class="mt-4 text-balance text-[1.8rem] font-semibold tracking-tight text-fb-ink sm:text-[2.2rem]">Common questions</h2>
        <div class="mt-5">
          <FAQList items={homepageFaqs} />
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell-tight pt-0">
    <div class="dark-panel p-5 sm:p-6 lg:p-7">
      <div class="grid gap-5 lg:grid-cols-[1fr_0.92fr] lg:items-center">
        <div>
          <span class="eyebrow border-white/15 bg-white/5 text-sky-100">Next step</span>
          <h2 class="mt-4 text-balance text-[1.8rem] font-semibold tracking-tight text-white sm:text-[2.2rem]">Discuss the right subject, level and lesson format.</h2>
          <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300">FlyBridge can help you decide whether the best next step is a callback or a full assessment.</p>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          <a class="cta-button justify-center bg-white text-fb-bg hover:bg-sky-50" href={site.assessmentHref}>Book Free Assessment</a>
          <a class="ghost-button justify-center border-white/15 bg-white/5 text-white hover:bg-white/10" href={site.callbackHref}>Request a Callback</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
