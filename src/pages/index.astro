---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SubjectOverviewCard from "../components/SubjectOverviewCard.astro";
import PricingCard from "../components/PricingCard.astro";
import FAQList from "../components/FAQList.astro";
import TestimonialGrid from "../components/TestimonialGrid.astro";
import CtaBanner from "../components/CtaBanner.astro";
import {
  assessmentFeatures,
  faqs,
  flybridgeMethod,
  heroMetrics,
  lessonFlow,
  parentReasons,
  pricingFeatures,
  progressTracking,
  site,
  subjectPages,
  testimonials,
  tutorHighlights
} from "../data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: site.url,
    description: site.description
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "GCSE science tuition",
    provider: {
      "@type": "EducationalOrganization",
      name: site.name,
      url: site.url
    },
    areaServed: "United Kingdom",
    description: site.description
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
      "@type": "Question",
      name: faq.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.answer
      }
    }))
  }
];
---

<BaseLayout
  title="Cambridge-trained GCSE Science Tuition"
  description={site.description}
  path="/"
  schema={schema}
>
  <PageHero
    eyebrow="Premium online GCSE science tuition"
    title="Cambridge-trained tuition built to earn parent trust and move students towards Grades 7-9."
    body="FlyBridge combines academic rigour, calm teaching and structured progress tracking so families can see exactly how science performance is improving."
    primaryLabel="Book Free Assessment"
    primaryHref={site.assessmentHref}
    secondaryLabel="Request a Callback"
    secondaryHref={site.callbackHref}
    tertiaryLabel="Student Hub"
    tertiaryHref="/student-hub"
    imageSrc={site.images.heroStudyDesk}
    imageAlt="A premium study desk setup representing focused GCSE science tuition."
    imageLoading="eager"
    imagePosition="center"
    imageBadge="Cambridge-trained support"
  />

  <section class="container-shell section-shell pt-0">
    <div class="grid gap-4 md:grid-cols-3">
      {heroMetrics.map((item) => (
        <div class="card-panel p-6">
          <p class="text-3xl font-semibold text-fb-ink">{item.value}</p>
          <p class="mt-3 text-sm leading-6 text-fb-ink-soft">{item.label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container-shell section-shell">
    <SectionHeading
      eyebrow="Why parents choose FlyBridge"
      title="A premium tuition experience designed to feel thoughtful, organised and genuinely effective."
      body="Parents are not just looking for extra lessons. They want credible teaching, steady communication and a clear path from concern to progress."
    />
    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {parentReasons.map((item) => (
        <div class="card-panel p-7">
          <h3 class="text-xl font-semibold text-fb-ink">{item.title}</h3>
          <p class="mt-3 text-base leading-7 text-fb-ink-soft">{item.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
      <SectionHeading
        eyebrow="Meet your tutor"
        title="Academic depth, GCSE focus and a calm teaching style that helps students engage."
        body="FlyBridge is built around the idea that students learn best when teaching is both rigorous and reassuring. High standards matter, but so does the way they are delivered."
      />
      <div class="card-panel p-7 sm:p-8">
        <div class="grid gap-5 lg:grid-cols-[0.95fr_1.05fr]">
          <div class="image-panel">
            <img
              src={site.images.bridgeBlueprint}
              alt="A premium bridge blueprint visual representing the FlyBridge mission and structure."
              class="h-full min-h-[260px] w-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="grid gap-5 sm:grid-cols-3 lg:grid-cols-1">
            {tutorHighlights.map((item) => (
              <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50/80 p-5">
                <h3 class="text-lg font-semibold text-fb-ink">{item.title}</h3>
                <p class="mt-3 text-sm leading-7 text-fb-ink-soft">{item.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="dark-panel section-grid relative overflow-hidden p-8 sm:p-10 lg:p-14">
      <div class="absolute right-0 top-0 h-48 w-48 -translate-y-12 translate-x-12 rounded-full bg-sky-400/20 blur-3xl"></div>
      <div class="relative">
        <SectionHeading
          eyebrow="The FlyBridge method"
          title="A simple, premium process that gives families clarity from the first conversation."
          body="The goal is to reduce uncertainty. Parents understand what the student needs, students know what to work on, and lessons stay focused."
        />
        <div class="mt-10 grid gap-5 md:grid-cols-[1.1fr_0.9fr] xl:grid-cols-[1.2fr_0.8fr]">
          <div class="image-panel order-2 md:order-1">
            <img
              src={site.images.learningPath}
              alt="A structured learning path visual representing the FlyBridge teaching method."
              class="h-full min-h-[320px] w-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="order-1 grid gap-5 md:order-2 md:grid-cols-2">
            {flybridgeMethod.map((item) => (
              <div class="rounded-[1.75rem] border border-white/10 bg-white/[0.05] p-6 backdrop-blur">
                <h3 class="text-xl font-semibold text-white">{item.title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-300">{item.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell">
    <SectionHeading
      eyebrow="Subjects"
      title="Dedicated support across GCSE science."
      body="Each subject page explains what is covered, how online lessons are structured and how FlyBridge approaches progress."
    />
    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {subjectPages.map((subject) => <SubjectOverviewCard subject={subject} />)}
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <SectionHeading
        eyebrow="How lessons work"
        title="Structured weekly tuition with clear expectations and no wasted time."
        body="The lesson experience is built for busy families who want consistency, quality and a strong sense of direction."
      />
      <div class="space-y-5">
        {lessonFlow.map((item, index) => (
          <div class="card-panel relative p-6 sm:p-7">
            {index !== lessonFlow.length - 1 && <div class="absolute left-12 top-[4.5rem] h-[calc(100%-2.25rem)] w-px bg-slate-200"></div>}
            <div class="flex gap-5">
              <div class="grid h-12 w-12 shrink-0 place-items-center rounded-2xl bg-fb-bg text-sm font-semibold text-white">{index + 1}</div>
              <div>
                <h3 class="text-xl font-semibold text-fb-ink">{item.title}</h3>
                <p class="mt-3 text-base leading-7 text-fb-ink-soft">{item.body}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
      <SectionHeading
        eyebrow="Progress tracking"
        title="Parents can see how support is translating into real progress."
        body="FlyBridge is designed to feel transparent. Materials, homework, revision guidance and feedback are organised so improvement is easier to spot and sustain."
      />
      <div class="grid gap-5 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="image-panel">
          <img
            src={site.images.progressDashboard}
            alt="A progress dashboard visual representing tracked GCSE science progress."
            class="h-full min-h-[300px] w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {progressTracking.map((item) => (
            <div class="card-panel px-5 py-4 text-base text-fb-ink">{item}</div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell">
    <SectionHeading
      eyebrow="Testimonials"
      title="Reassuring social proof, ready for real parent feedback."
      body="Placeholder testimonials are included for now so the section is ready to swap once live client feedback is collected."
    />
    <div class="mt-10">
      <TestimonialGrid items={testimonials} />
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <SectionHeading
        eyebrow="Pricing"
        title="Straightforward pricing with the free assessment built in."
        body="Start with an assessment so recommendations are based on the student's actual needs rather than a generic package."
      />
      <PricingCard
        price="£20"
        ctaLabel="Book Free Assessment"
        ctaHref={site.assessmentHref}
        features={pricingFeatures}
        note="Final tuition fees may vary depending on year group, lesson format and availability."
      />
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.88fr_1.12fr] lg:items-center">
      <SectionHeading
        eyebrow="Free assessment"
        title="A calm first step for parents who want clarity before committing."
        body="The assessment is designed to be genuinely useful. It helps identify where the student is now, what is holding them back and what support would make the biggest difference."
      />
      <div class="grid gap-5 lg:grid-cols-[1fr_0.9fr]">
        <div class="grid gap-4 sm:grid-cols-2">
          {assessmentFeatures.map((item) => (
            <div class="card-panel px-5 py-4 text-base text-fb-ink">{item}</div>
          ))}
        </div>
        <div class="image-panel">
          <img
            src={site.images.assessmentReport}
            alt="An assessment report visual representing FlyBridge's free assessment and reporting process."
            class="h-full min-h-[280px] w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <SectionHeading
        eyebrow="FAQ preview"
        title="A few of the questions parents usually ask first."
        body="Detailed answers are available on the full FAQs page."
      />
      <a class="ghost-button" href="/faqs">View all FAQs</a>
    </div>
    <div class="mt-10">
      <FAQList items={faqs.slice(0, 4)} />
    </div>
  </section>

  <CtaBanner
    eyebrow="Get started"
    title="Book a free assessment and take the uncertainty out of GCSE science support."
    body="Whether your child needs stronger foundations, sharper exam technique or a more consistent approach to revision, FlyBridge can help you map the next step."
    actions={[
      { label: "Book Free Assessment", href: site.assessmentHref },
      { label: "Request a Callback", href: site.callbackHref, variant: "secondary" },
      { label: "WhatsApp", href: site.whatsappHref, variant: "secondary" },
      { label: "Email", href: `mailto:${site.email}`, variant: "secondary" }
    ]}
  />
</BaseLayout>
