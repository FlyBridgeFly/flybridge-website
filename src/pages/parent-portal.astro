---
import BaseLayout from "../layouts/BaseLayout.astro";
import DashboardLayout from "../components/DashboardLayout.astro";
import RoleGuard from "../components/RoleGuard.astro";
import ParentStudentDashboard from "../components/ParentStudentDashboard.astro";
import StudentCard from "../components/StudentCard.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "FlyBridge Parent Reporting Portal",
  description: "Parent-only portal for linked students, lesson reports, assessments and targets.",
  url: new URL("/parent-portal", site.url).toString()
};
---

<BaseLayout
  title="Parent Portal"
  description="Parent-only portal for linked students, lesson reports, assessments and targets."
  path="/parent-portal"
  schema={schema}
  noindex={true}
>
  <DashboardLayout
    title="Parent reporting portal"
    description="A calm, read-only space for families to follow lesson reporting, assessments and targets."
    active="parent"
  >
    <RoleGuard>
      <section class="grid gap-5 md:grid-cols-2">
        <StudentCard title="0" subtitle="Students linked to your account through `parent_student_links`." meta="Linked students">
          <p class="mt-4 text-3xl font-semibold text-fb-ink" data-parent-student-count>0</p>
        </StudentCard>
        <article class="card-panel p-6">
          <p class="text-xs font-semibold tracking-[0.18em] text-slate-500 uppercase">Read only</p>
          <h2 class="mt-2 text-2xl font-semibold text-fb-ink">Everything in one place.</h2>
          <p class="mt-3 text-sm leading-7 text-fb-ink-soft">Parents can view lesson reports, assessments and targets for linked students, but cannot edit academic records from this portal.</p>
        </article>
      </section>

      <ParentStudentDashboard containerId="parent-reporting-dashboard" />
    </RoleGuard>
  </DashboardLayout>

  <script>
    import { bootstrapParentPortal } from "../lib/parent-portal";

    bootstrapParentPortal().catch((error) => {
      const target = document.querySelector("[data-role-error-message]");
      if (target instanceof HTMLElement) {
        target.textContent = error instanceof Error ? error.message : "Parent portal failed to load.";
      }
    });
  </script>
</BaseLayout>
