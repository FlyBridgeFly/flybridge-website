---
import BaseLayout from "../layouts/BaseLayout.astro";
import { consultancyServices, site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Educational consultancy",
  provider: {
    "@type": "EducationalOrganization",
    name: site.name,
    url: site.url
  },
  description: "Educational consultancy support from FlyBridge Education, including study skills, revision planning, academic mentoring and transition guidance."
};
---

<BaseLayout
  title="Educational Consultancy"
  description="Educational consultancy support from FlyBridge Education, including study skills, revision planning, academic mentoring and transition guidance."
  path="/educational-consultancy"
  schema={schema}
>
  <section class="container-shell section-shell-tight">
    <div class="grid gap-5 lg:grid-cols-[1.04fr_0.96fr] lg:items-end">
      <div class="space-y-4">
        <span class="eyebrow">Educational Consultancy</span>
        <h1 class="text-balance text-[2rem] font-semibold tracking-tight text-fb-ink sm:text-[2.6rem] lg:text-[3rem]">
          Broader academic guidance for families who need support beyond weekly tuition.
        </h1>
        <p class="max-w-3xl body-copy-compact">
          Consultancy is a secondary FlyBridge service for families who need study structure, planning or mentoring rather than a standard lesson arrangement.
        </p>
      </div>
      <div class="dashboard-list">
        <div class="dashboard-list-item">
          <p class="text-xs font-semibold tracking-[0.16em] text-slate-500 uppercase">When it is useful</p>
          <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Revision planning, academic routines, transitions, longer-term study choices and broader mentoring conversations.</p>
        </div>
        <div class="dashboard-list-item">
          <p class="text-xs font-semibold tracking-[0.16em] text-slate-500 uppercase">How to enquire</p>
          <p class="mt-2 text-sm leading-6 text-fb-ink-soft">The best next step is a direct message or email so the enquiry can be discussed around the student’s situation.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell-tight pt-0">
    <div class="dashboard-card-grid md:grid-cols-2 xl:grid-cols-3">
      {consultancyServices.map((service) => (
        <article class="dashboard-section">
          <h2 class="text-lg font-semibold text-fb-ink">{service.title}</h2>
          <p class="mt-3 text-sm leading-6 text-fb-ink-soft">{service.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container-shell section-shell-tight pt-0">
    <div class="dark-panel p-5 sm:p-6 lg:p-7">
      <div class="grid gap-4 lg:grid-cols-[1fr_0.92fr] lg:items-center">
        <div>
          <span class="eyebrow border-white/15 bg-white/5 text-sky-100">Consultancy enquiry</span>
          <h2 class="mt-4 text-balance text-[1.8rem] font-semibold tracking-tight text-white sm:text-[2.2rem]">Message FlyBridge to discuss the right kind of support.</h2>
          <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300">A short WhatsApp message or email is usually the quickest way to explain context and receive a tailored reply.</p>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          <a class="cta-button justify-center bg-white text-fb-bg hover:bg-sky-50" href={`mailto:${site.email}`}>Email FlyBridge</a>
          <a class="ghost-button justify-center border-white/15 bg-white/5 text-white hover:bg-white/10" href={site.whatsappHref} target="_blank" rel="noreferrer">WhatsApp</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
