---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "FlyBridge Portal Password Reset",
  description: "Request a password reset link for the FlyBridge parent or tutor portal.",
  url: new URL("/forgot-password", site.url).toString()
};
---

<BaseLayout
  title="Forgot Password"
  description="Request a password reset link for the FlyBridge parent or tutor portal."
  path="/forgot-password"
  schema={schema}
  noindex={true}
>
  <section class="container-shell pb-8 pt-5 sm:pb-10 sm:pt-6">
    <div class="mx-auto grid max-w-4xl gap-5 lg:grid-cols-[0.92fr_1.08fr]">
      <article class="card-panel p-5 sm:p-6">
        <span class="eyebrow">Portal support</span>
        <h1 class="mt-4 text-[2rem] font-semibold tracking-tight text-fb-ink sm:text-[2.5rem]">Reset access calmly.</h1>
        <p class="mt-3 body-copy">
          Enter the tutor or parent email linked to FlyBridge and we will send a secure password reset link if the account exists.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="mini-chip">Tutor access</span>
          <span class="mini-chip">Parent access</span>
          <span class="mini-chip">Secure reset link</span>
        </div>
      </article>

      <form class="form-panel" data-forgot-password-form>
        <h2 class="text-xl font-semibold tracking-tight text-fb-ink sm:text-2xl">Request reset link</h2>
        <p class="mt-3 body-copy">Use the invited email address for the portal account you want to recover.</p>
        <div class="form-grid-compact !mt-6 !grid-cols-1">
          <label>
            <span class="label-shell">Email</span>
            <input class="input-shell" name="email" type="email" placeholder="parent@example.com" required autocomplete="email" />
          </label>
        </div>
        <p class="status-message mt-4 hidden" data-forgot-password-feedback role="status" aria-live="polite"></p>
        <div class="form-actions">
          <button class="cta-button w-full sm:w-auto" type="submit">Send reset link</button>
          <a class="ghost-button w-full sm:w-auto" href="/login">Back to login</a>
        </div>
      </form>
    </div>
  </section>

  <script>
    import { bootstrapForgotPasswordPage, getFriendlyErrorMessage } from "../lib/portal-client";

    bootstrapForgotPasswordPage().catch(async (error) => {
      const feedback = document.querySelector("[data-forgot-password-feedback]");
      if (feedback instanceof HTMLElement) {
        feedback.classList.remove("hidden");
        feedback.classList.add("status-error");
        feedback.textContent = await getFriendlyErrorMessage(error, "Password reset is not available right now.");
      }
    });
  </script>
</BaseLayout>
