---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Change FlyBridge Portal Password",
  description: "Change your FlyBridge portal password after first sign-in.",
  url: new URL("/change-password", site.url).toString()
};
---

<BaseLayout
  title="Change Password"
  description="Change your FlyBridge portal password after first sign-in."
  path="/change-password"
  schema={schema}
  noindex={true}
>
  <section class="container-shell pb-8 pt-5 sm:pb-10 sm:pt-6">
    <div class="mx-auto grid max-w-4xl gap-5 lg:grid-cols-[0.92fr_1.08fr]">
      <article class="card-panel p-5 sm:p-6">
        <span class="eyebrow">Secure first login</span>
        <h1 class="mt-4 text-[2rem] font-semibold tracking-tight text-fb-ink sm:text-[2.5rem]">Set your new password.</h1>
        <p class="mt-3 body-copy">
          If FlyBridge issued a temporary password, update it here before continuing to your parent or tutor dashboard.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="mini-chip">First-login security</span>
          <span class="mini-chip">Parent & tutor portal</span>
        </div>
      </article>

      <form class="form-panel" data-change-password-form>
        <h2 class="text-xl font-semibold tracking-tight text-fb-ink sm:text-2xl">Choose a new password</h2>
        <div class="surface-note mt-4">Choose a password you will remember easily, then FlyBridge will return you to the correct dashboard automatically.</div>
        <div class="form-grid-compact !mt-6 !grid-cols-1">
          <label>
            <span class="label-shell">New password</span>
            <input class="input-shell" name="password" type="password" required autocomplete="new-password" minlength="8" />
          </label>
          <label>
            <span class="label-shell">Confirm new password</span>
            <input class="input-shell" name="confirm-password" type="password" required autocomplete="new-password" minlength="8" />
          </label>
        </div>
        <p class="status-message mt-4 hidden" data-change-password-feedback role="status" aria-live="polite"></p>
        <div class="form-actions">
          <button class="cta-button w-full sm:w-auto" type="submit">Update password</button>
        </div>
      </form>
    </div>
  </section>

  <script>
    import { bootstrapChangePasswordPage, getFriendlyErrorMessage } from "../lib/portal-client";

    bootstrapChangePasswordPage().catch(async (error) => {
      const feedback = document.querySelector("[data-change-password-feedback]");
      if (feedback instanceof HTMLElement) {
        feedback.classList.remove("hidden");
        feedback.classList.add("status-error");
        feedback.textContent = await getFriendlyErrorMessage(error, "Password update is not available right now.");
      }
    });
  </script>
</BaseLayout>
