---
import BaseLayout from "../layouts/BaseLayout.astro";
import DashboardLayout from "../components/DashboardLayout.astro";
import RoleGuard from "../components/RoleGuard.astro";
import LessonReportForm from "../components/LessonReportForm.astro";
import AssessmentForm from "../components/AssessmentForm.astro";
import TargetForm from "../components/TargetForm.astro";
import EmptyState from "../components/EmptyState.astro";
import StudentCard from "../components/StudentCard.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "FlyBridge Tutor Dashboard",
  description: "Tutor portal for assigned students, lesson reports, assessments and targets.",
  url: new URL("/tutor", site.url).toString()
};
---

<BaseLayout
  title="Tutor Dashboard"
  description="Tutor portal for assigned students, lesson reports, assessments and targets."
  path="/tutor"
  schema={schema}
  noindex={true}
  showHeader={false}
  showFooter={false}
>
  <DashboardLayout
    title="Tutor dashboard"
    description="Stay focused on assigned students, upcoming lessons and the latest reporting work."
    active="tutor"
  >
    <RoleGuard>
      <section class="dashboard-metric-grid">
        <StudentCard title="Assigned students" subtitle="Students currently linked to your profile." meta="Students">
          <p class="mt-4 text-3xl font-semibold text-fb-ink" data-student-count>0</p>
        </StudentCard>
        <StudentCard title="Active targets" subtitle="Open targets across your currently assigned students." meta="Targets">
          <p class="mt-4 text-3xl font-semibold text-fb-ink" data-target-count>0</p>
        </StudentCard>
        <StudentCard title="Reports logged" subtitle="Lesson report history visible in the parent portal." meta="Reporting">
          <p class="mt-4 text-3xl font-semibold text-fb-ink" data-report-count>0</p>
        </StudentCard>
        <section class="dashboard-section">
          <div class="dashboard-section-heading">
            <h1 class="text-xl font-semibold tracking-tight text-fb-ink sm:text-2xl">Teaching workspace</h1>
            <p class="body-copy-compact">Select a student card to prefill the forms below, then record the latest lesson, checkpoint or target update.</p>
          </div>
          <div class="mt-4 flex flex-wrap gap-2">
            <a class="quick-add-chip" href="#tutor-report-form">Add feedback</a>
            <a class="quick-add-chip" href="#tutor-assessment-form">Add assessment</a>
            <a class="quick-add-chip" href="#tutor-target-form">Update target</a>
          </div>
        </section>
      </section>

      <section class="dashboard-split-grid">
        <section class="dashboard-section">
          <div class="dashboard-section-heading">
            <h2 class="text-xl font-semibold tracking-tight text-fb-ink sm:text-2xl">Assigned students</h2>
            <p class="body-copy-compact">Student status and quick actions for reporting.</p>
          </div>
          <div class="dashboard-card-grid mt-4" data-tutor-students>
            <EmptyState title="Loading assigned students" body="Assigned students are being loaded for your dashboard." />
          </div>
        </section>
        <section class="dashboard-section">
          <div class="dashboard-section-heading">
            <h2 class="text-xl font-semibold tracking-tight text-fb-ink sm:text-2xl">Upcoming lessons</h2>
            <p class="body-copy-compact">Scheduled sessions across your assigned students.</p>
          </div>
          <div class="dashboard-card-stack mt-4" data-tutor-lessons>
            <EmptyState title="Loading lessons" body="Upcoming lessons are being loaded for your dashboard." />
          </div>
        </section>
      </section>

      <section class="dashboard-compact-grid">
        <LessonReportForm formId="tutor-report-form" />
        <AssessmentForm formId="tutor-assessment-form" />
      </section>

      <section class="dashboard-split-grid">
        <TargetForm formId="tutor-target-form" />
        <div class="dashboard-section">
          <h2 class="text-xl font-semibold tracking-tight text-fb-ink sm:text-2xl">Current targets</h2>
          <p class="mt-2 body-copy-compact">Choose an existing target to load it into the form for updating.</p>
          <div class="dashboard-card-stack mt-4" data-target-editor>
            <div class="rounded-[1rem] border border-dashed border-slate-200 bg-white p-4 text-sm text-fb-ink-soft">Loading current targets for your assigned students...</div>
          </div>
        </div>
      </section>

      <section class="dashboard-section">
        <div class="dashboard-section-heading">
          <h2 class="text-xl font-semibold tracking-tight text-fb-ink sm:text-2xl">Recent report activity</h2>
          <p class="body-copy-compact">A compact timeline of the most recent parent-facing updates you can review at a glance.</p>
        </div>
        <div class="dashboard-card-stack mt-4" data-tutor-reports>
          <EmptyState title="Loading reports" body="Recent lesson reports are being loaded for your dashboard." />
        </div>
      </section>
    </RoleGuard>
  </DashboardLayout>

  <script>
    import { bootstrapTutorDashboard } from "../lib/tutor-dashboard";
    import { getFriendlyErrorMessage } from "../lib/portal-client";

    bootstrapTutorDashboard().catch(async (error) => {
      const target = document.querySelector("[data-role-error-message]");
      if (target instanceof HTMLElement) {
        target.textContent = await getFriendlyErrorMessage(error, "Tutor dashboard failed to load.");
      }
    });
  </script>
</BaseLayout>
