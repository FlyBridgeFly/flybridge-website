---
import BaseLayout from "../layouts/BaseLayout.astro";
import DashboardLayout from "../components/DashboardLayout.astro";
import RoleGuard from "../components/RoleGuard.astro";
import LessonReportForm from "../components/LessonReportForm.astro";
import AssessmentForm from "../components/AssessmentForm.astro";
import TargetForm from "../components/TargetForm.astro";
import EmptyState from "../components/EmptyState.astro";
import StudentCard from "../components/StudentCard.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "FlyBridge Tutor Dashboard",
  description: "Tutor portal for assigned students, lesson reports, assessments and targets.",
  url: new URL("/tutor", site.url).toString()
};
---

<BaseLayout
  title="Tutor Dashboard"
  description="Tutor portal for assigned students, lesson reports, assessments and targets."
  path="/tutor"
  schema={schema}
  noindex={true}
>
  <DashboardLayout
    title="Tutor dashboard"
    description="Work only with the students linked to your profile, then keep reporting current and parent-ready."
    active="tutor"
  >
    <RoleGuard>
      <section class="grid gap-4 lg:grid-cols-[0.88fr_1.12fr]">
        <StudentCard title="Students in view" subtitle="Students currently linked to your profile and ready for lesson reporting, assessments and target updates." meta="Assigned students">
          <p class="mt-4 text-3xl font-semibold text-fb-ink" data-student-count>0</p>
        </StudentCard>
        <article class="card-panel p-4 sm:p-5">
          <p class="text-xs font-semibold tracking-[0.18em] text-slate-500 uppercase">Tutor focus</p>
          <h2 class="mt-2 text-xl font-semibold text-fb-ink sm:text-2xl">Capture progress clearly.</h2>
          <p class="mt-3 body-copy">This dashboard is designed for fast, parent-ready reporting: view assigned students, log the lesson, record the checkpoint and keep targets current without extra admin overhead.</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="mini-chip">Quick lesson updates</span>
            <span class="mini-chip">Assessment tracking</span>
            <span class="mini-chip">Shared targets</span>
          </div>
        </article>
      </section>

      <section class="dashboard-section">
        <div class="surface-note">
          Choose a student card first to pre-fill the reporting forms below. That keeps lesson reports, assessments and targets faster to complete on mobile and tablet.
        </div>
      </section>

      <section class="dashboard-section">
        <div class="dashboard-section-heading">
          <h2 class="text-xl font-semibold tracking-tight text-fb-ink sm:text-2xl">Assigned students</h2>
          <p class="body-copy">Students only appear here when an admin has linked them to your profile.</p>
        </div>
        <div class="dashboard-card-grid mt-4" data-tutor-students>
          <EmptyState title="Loading assigned students" body="Assigned students are being loaded for your dashboard." />
        </div>
      </section>

      <section class="grid gap-5 xl:grid-cols-2">
        <LessonReportForm formId="tutor-report-form" />
        <AssessmentForm formId="tutor-assessment-form" />
      </section>

      <section class="grid gap-5 xl:grid-cols-[0.95fr_1.05fr]">
        <TargetForm formId="tutor-target-form" />
        <div class="dashboard-section">
          <h2 class="text-xl font-semibold tracking-tight text-fb-ink sm:text-2xl">Current targets</h2>
          <p class="mt-3 body-copy">Choose an existing target to load it into the form for updating.</p>
          <div class="dashboard-card-stack mt-4" data-target-editor>
            <div class="rounded-[1rem] border border-dashed border-slate-200 bg-white p-4 text-sm text-fb-ink-soft">Loading current targets for your assigned students...</div>
          </div>
        </div>
      </section>
    </RoleGuard>
  </DashboardLayout>

  <script>
    import { bootstrapTutorDashboard } from "../lib/tutor-dashboard";
    import { getFriendlyErrorMessage } from "../lib/portal-client";

    bootstrapTutorDashboard().catch(async (error) => {
      const target = document.querySelector("[data-role-error-message]");
      if (target instanceof HTMLElement) {
        target.textContent = await getFriendlyErrorMessage(error, "Tutor dashboard failed to load.");
      }
    });
  </script>
</BaseLayout>
