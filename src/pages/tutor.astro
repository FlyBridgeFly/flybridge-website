---
import BaseLayout from "../layouts/BaseLayout.astro";
import DashboardLayout from "../components/DashboardLayout.astro";
import RoleGuard from "../components/RoleGuard.astro";
import LessonReportForm from "../components/LessonReportForm.astro";
import AssessmentForm from "../components/AssessmentForm.astro";
import TargetForm from "../components/TargetForm.astro";
import EmptyState from "../components/EmptyState.astro";
import StudentCard from "../components/StudentCard.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "FlyBridge Tutor Dashboard",
  description: "Tutor portal for assigned students, lesson reports, assessments and targets.",
  url: new URL("/tutor", site.url).toString()
};
---

<BaseLayout
  title="Tutor Dashboard"
  description="Tutor portal for assigned students, lesson reports, assessments and targets."
  path="/tutor"
  schema={schema}
  noindex={true}
>
  <DashboardLayout
    title="Tutor dashboard"
    description="Work only with the students linked to your profile, then keep reporting current and parent-ready."
    active="tutor"
  >
    <RoleGuard>
      <section class="grid gap-5 md:grid-cols-2">
        <StudentCard title="0" subtitle="Students currently linked to your profile through `tutor_student_links`." meta="Assigned students">
          <p class="mt-4 text-3xl font-semibold text-fb-ink" data-student-count>0</p>
        </StudentCard>
        <article class="card-panel p-6">
          <p class="text-xs font-semibold tracking-[0.18em] text-slate-500 uppercase">Tutor focus</p>
          <h2 class="mt-2 text-2xl font-semibold text-fb-ink">Capture progress clearly.</h2>
          <p class="mt-3 text-sm leading-7 text-fb-ink-soft">The dashboard is intentionally streamlined: see assigned students, log lessons, record assessments and keep targets current.</p>
        </article>
      </section>

      <section class="space-y-5">
        <div class="space-y-2">
          <h2 class="text-2xl font-semibold tracking-tight text-fb-ink">Assigned students</h2>
          <p class="text-sm leading-7 text-fb-ink-soft">Students only appear here when an admin has linked them to your profile.</p>
        </div>
        <div class="grid gap-4 md:grid-cols-2" data-tutor-students>
          <EmptyState title="Loading assigned students" body="Assigned students are being loaded from Supabase." />
        </div>
      </section>

      <section class="grid gap-6 xl:grid-cols-2">
        <LessonReportForm formId="tutor-report-form" />
        <AssessmentForm formId="tutor-assessment-form" />
      </section>

      <section class="grid gap-6 xl:grid-cols-[0.95fr_1.05fr]">
        <TargetForm formId="tutor-target-form" />
        <div class="card-panel p-7">
          <h2 class="text-2xl font-semibold tracking-tight text-fb-ink">Current targets</h2>
          <p class="mt-3 text-sm leading-7 text-fb-ink-soft">Choose an existing target to load it into the form for updating.</p>
          <div class="mt-6 space-y-3" data-target-editor>
            <div class="rounded-[1.5rem] border border-dashed border-slate-200 bg-white p-5 text-sm text-fb-ink-soft">Loading targets...</div>
          </div>
        </div>
      </section>
    </RoleGuard>
  </DashboardLayout>

  <script>
    import { bootstrapTutorDashboard } from "../lib/tutor-dashboard";

    bootstrapTutorDashboard().catch((error) => {
      const target = document.querySelector("[data-role-error-message]");
      if (target instanceof HTMLElement) {
        target.textContent = error instanceof Error ? error.message : "Tutor dashboard failed to load.";
      }
    });
  </script>
</BaseLayout>
