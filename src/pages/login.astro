---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "FlyBridge Portal Login",
  description: "Sign in to the FlyBridge portal.",
  url: new URL("/login", site.url).toString()
};
---

<BaseLayout
  title="Portal Login"
  description="Sign in to the FlyBridge portal."
  path="/login"
  schema={schema}
>
  <section class="container-shell pb-8 pt-5 sm:pb-10 sm:pt-6">
    <div class="mx-auto grid max-w-4xl gap-5 lg:grid-cols-[0.92fr_1.08fr] lg:gap-6">
      <div class="card-panel p-5 sm:p-6">
        <span class="eyebrow">FlyBridge portal</span>
        <h1 class="mt-4 text-[1.95rem] font-semibold tracking-tight text-fb-ink sm:text-[2.45rem]" data-login-heading>Welcome back</h1>
        <p class="mt-3 body-copy" data-login-body>Sign in to access your FlyBridge portal.</p>
        <div class="mt-5 grid gap-3">
          <div class="dashboard-list-item">
            <p class="text-sm font-semibold text-fb-ink">Parents</p>
            <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Lesson updates, assessments and current targets for linked students.</p>
          </div>
          <div class="dashboard-list-item">
            <p class="text-sm font-semibold text-fb-ink">Tutors</p>
            <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Assigned students, lesson reporting, assessments and targets.</p>
          </div>
        </div>
      </div>

      <form class="card-panel p-5 sm:p-6" data-login-form>
        <h2 class="text-xl font-semibold tracking-tight text-fb-ink sm:text-2xl">Portal login</h2>
        <p class="mt-3 body-copy-compact">Use the email address and password linked to your FlyBridge portal.</p>
        <div class="form-grid !mt-6 !grid-cols-1">
          <label>
            <span class="label-shell">Email</span>
            <input class="input-shell" name="email" type="email" placeholder="parent@example.com" required autocomplete="email" inputmode="email" />
          </label>
          <label>
            <span class="label-shell">Password</span>
            <input class="input-shell" name="password" type="password" placeholder="Your password" required autocomplete="current-password" />
          </label>
        </div>
        <p class="status-message mt-4 hidden" data-login-feedback role="status" aria-live="polite"></p>
        <div class="form-actions">
          <button class="cta-button w-full sm:w-auto" type="submit">Sign in</button>
          <a class="ghost-button w-full sm:w-auto" href="/forgot-password">Forgot password?</a>
        </div>
      </form>
    </div>
  </section>

  <script>
    import { bootstrapLoginPage, getFriendlyErrorMessage } from "../lib/portal-client";

    const params = new URLSearchParams(window.location.search);
    const portal = params.get("portal");
    const heading = document.querySelector("[data-login-heading]");
    const body = document.querySelector("[data-login-body]");

    if (heading instanceof HTMLElement && body instanceof HTMLElement) {
      if (portal === "parent") {
        heading.textContent = "Parent portal login";
        body.textContent = "Sign in to access your FlyBridge parent portal.";
      } else if (portal === "tutor") {
        heading.textContent = "Tutor portal login";
        body.textContent = "Sign in to access your FlyBridge tutor portal.";
      }
    }

    bootstrapLoginPage().catch(async (error) => {
      const feedback = document.querySelector("[data-login-feedback]");
      if (feedback instanceof HTMLElement) {
        feedback.classList.remove("hidden");
        feedback.classList.remove("status-success", "status-info");
        feedback.classList.add("status-message", "status-error");
        feedback.textContent = await getFriendlyErrorMessage(error, "Portal login is not available right now.");
      }
    });
  </script>
</BaseLayout>
