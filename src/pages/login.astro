---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "FlyBridge Portal Login",
  description: "Sign in to the FlyBridge admin, tutor or parent reporting portal.",
  url: new URL("/login", site.url).toString()
};
---

<BaseLayout
  title="Portal Login"
  description="Sign in to the FlyBridge admin, tutor or parent reporting portal."
  path="/login"
  schema={schema}
>
  <section class="container-shell pb-16 pt-10 sm:pt-14">
    <div class="mx-auto max-w-5xl grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="card-panel p-8 sm:p-10">
        <span class="eyebrow">FlyBridge portal</span>
        <h1 class="mt-6 text-4xl font-semibold tracking-tight text-fb-ink sm:text-5xl">Sign in to continue.</h1>
        <p class="mt-4 text-base leading-8 text-fb-ink-soft">
          This login is used for administrators, tutors and parents. Access inside the portal is controlled by the role stored on your Supabase `profiles` record.
        </p>
        <div class="mt-8 grid gap-4">
          <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50/80 p-5">
            <p class="text-sm font-semibold text-fb-ink">Admin</p>
            <p class="mt-2 text-sm leading-7 text-fb-ink-soft">View all students, assign tutors, create reports and manage assessment activity.</p>
          </div>
          <div class="rounded-[1.5rem] border border-slate-200 bg-white p-5">
            <p class="text-sm font-semibold text-fb-ink">Tutor</p>
            <p class="mt-2 text-sm leading-7 text-fb-ink-soft">See assigned students only, then record lesson reports, assessments and targets.</p>
          </div>
          <div class="rounded-[1.5rem] border border-slate-200 bg-white p-5">
            <p class="text-sm font-semibold text-fb-ink">Parent</p>
            <p class="mt-2 text-sm leading-7 text-fb-ink-soft">Read linked student reports, assessments and targets in one calm dashboard.</p>
          </div>
        </div>
      </div>

      <form class="card-panel p-8 sm:p-10" data-login-form>
        <h2 class="text-2xl font-semibold tracking-tight text-fb-ink">Portal login</h2>
        <p class="mt-3 text-sm leading-7 text-fb-ink-soft">
          Use the same email address and password you created in Supabase Auth for your FlyBridge portal account.
        </p>
        <div class="mt-8 grid gap-5">
          <label>
            <span class="label-shell">Email</span>
            <input class="input-shell" name="email" type="email" placeholder="parent@example.com" />
          </label>
          <label>
            <span class="label-shell">Password</span>
            <input class="input-shell" name="password" type="password" placeholder="Your password" />
          </label>
        </div>
        <p class="mt-5 hidden text-sm font-medium" data-login-feedback></p>
        <button class="cta-button mt-6" type="submit">Sign in</button>
        <div class="mt-6 rounded-[1.5rem] border border-slate-200 bg-slate-50/80 p-5 text-sm leading-7 text-fb-ink-soft">
          Tutor and parent accounts must currently be created manually in Supabase Auth, then linked to a `profiles` row with the correct role.
        </div>
      </form>
    </div>
  </section>

  <script>
    import { bootstrapLoginPage } from "../lib/portal-client";

    bootstrapLoginPage().catch((error) => {
      const feedback = document.querySelector("[data-login-feedback]");
      if (feedback instanceof HTMLElement) {
        feedback.classList.remove("hidden");
        feedback.classList.add("text-rose-700");
        feedback.textContent = error instanceof Error ? error.message : "Portal login is not available right now.";
      }
    });
  </script>
</BaseLayout>
