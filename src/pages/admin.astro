---
import BaseLayout from "../layouts/BaseLayout.astro";
import DashboardLayout from "../components/DashboardLayout.astro";
import RoleGuard from "../components/RoleGuard.astro";
import LessonReportForm from "../components/LessonReportForm.astro";
import AssessmentForm from "../components/AssessmentForm.astro";
import TargetForm from "../components/TargetForm.astro";
import ReportTimeline from "../components/ReportTimeline.astro";
import EmptyState from "../components/EmptyState.astro";
import StudentCard from "../components/StudentCard.astro";
import { site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "FlyBridge Admin Dashboard",
  description: "Admin portal for FlyBridge reporting, student setup and tutor assignment.",
  url: new URL("/admin", site.url).toString()
};
---

<BaseLayout
  title="Admin Dashboard"
  description="Admin portal for FlyBridge reporting, student setup and tutor assignment."
  path="/admin"
  schema={schema}
  noindex={true}
>
  <DashboardLayout
    title="Admin dashboard"
    description="Manage students, assign tutors and keep FlyBridge reporting current."
    active="admin"
  >
    <RoleGuard>
      <section class="grid gap-5 md:grid-cols-3">
        <StudentCard title="0" subtitle="Total students visible across the portal." meta="Students">
          <p class="mt-4 text-3xl font-semibold text-fb-ink" data-student-count>0</p>
        </StudentCard>
        <StudentCard title="0" subtitle="Tutor profiles currently marked with the `tutor` role." meta="Tutors">
          <p class="mt-4 text-3xl font-semibold text-fb-ink" data-tutor-count>0</p>
        </StudentCard>
        <StudentCard title="0" subtitle="Most recent lesson reports pulled from Supabase." meta="Reports">
          <p class="mt-4 text-3xl font-semibold text-fb-ink" data-report-count>0</p>
        </StudentCard>
      </section>

      <section class="space-y-5">
        <div class="space-y-2">
          <h2 class="text-2xl font-semibold tracking-tight text-fb-ink">Students</h2>
          <p class="text-sm leading-7 text-fb-ink-soft">All students currently visible to the admin profile appear below.</p>
        </div>
        <div class="grid gap-4 md:grid-cols-2" data-admin-students>
          <EmptyState title="Loading students" body="Student records are being loaded from Supabase." />
        </div>
      </section>

      <section class="grid gap-6 xl:grid-cols-2">
        <form class="card-panel p-7" data-student-form>
          <h2 class="text-2xl font-semibold tracking-tight text-fb-ink">Create student</h2>
          <p class="mt-3 text-sm leading-7 text-fb-ink-soft">Add a student record so tutors and parents can be linked to it later.</p>
          <div class="mt-6 grid gap-5 sm:grid-cols-2">
            <label class="sm:col-span-2">
              <span class="label-shell">Student full name</span>
              <input class="input-shell" name="full-name" type="text" placeholder="Aisha Khan" />
            </label>
            <label>
              <span class="label-shell">Year group</span>
              <input class="input-shell" name="year-group" type="text" placeholder="Year 10" />
            </label>
            <label>
              <span class="label-shell">School</span>
              <input class="input-shell" name="school" type="text" placeholder="School name" />
            </label>
            <label class="sm:col-span-2">
              <span class="label-shell">Notes</span>
              <textarea class="input-shell min-h-24 resize-y" name="notes" placeholder="Optional notes for internal use"></textarea>
            </label>
          </div>
          <p class="mt-5 hidden text-sm font-medium" data-form-status></p>
          <button class="cta-button mt-6" type="submit">Create student</button>
        </form>

        <article class="card-panel p-7">
          <h2 class="text-2xl font-semibold tracking-tight text-fb-ink">Create tutor profile</h2>
          <p class="mt-3 text-sm leading-7 text-fb-ink-soft">
            For security, tutor and parent accounts are not created from the frontend. Use Supabase Auth manually, then ensure a matching `profiles` row exists with `role = tutor`.
          </p>
          <div class="mt-6 grid gap-5 sm:grid-cols-2">
            <label>
              <span class="label-shell">Tutor name</span>
              <input class="input-shell" type="text" placeholder="Future tutor display name" disabled />
            </label>
            <label>
              <span class="label-shell">Tutor email</span>
              <input class="input-shell" type="email" placeholder="tutor@example.com" disabled />
            </label>
          </div>
          <div class="mt-6 rounded-[1.5rem] border border-slate-200 bg-slate-50/80 p-5 text-sm leading-7 text-fb-ink-soft">
            Recommended flow:
            Create the user in Supabase Auth.
            Confirm the `profiles` row exists for that user.
            Set the `role` column to `tutor`.
            Return here to assign the tutor to one or more students.
          </div>
        </article>
      </section>

      <section class="grid gap-6 xl:grid-cols-2">
        <form class="card-panel p-7" data-assign-form>
          <h2 class="text-2xl font-semibold tracking-tight text-fb-ink">Assign tutor to student</h2>
          <p class="mt-3 text-sm leading-7 text-fb-ink-soft">This creates a record in `tutor_student_links` so the tutor sees that student in their dashboard.</p>
          <div class="mt-6 grid gap-5">
            <label>
              <span class="label-shell">Tutor profile</span>
              <select class="input-shell" name="tutor-id" data-tutor-select></select>
            </label>
            <label>
              <span class="label-shell">Student</span>
              <select class="input-shell" name="student-id" data-student-select></select>
            </label>
          </div>
          <p class="mt-5 hidden text-sm font-medium" data-form-status></p>
          <button class="cta-button mt-6" type="submit">Assign tutor</button>
        </form>

        <div class="card-panel p-7">
          <h2 class="text-2xl font-semibold tracking-tight text-fb-ink">Current targets</h2>
          <p class="mt-3 text-sm leading-7 text-fb-ink-soft">Select an existing target to load it into the edit form below.</p>
          <div class="mt-6 space-y-3" data-target-editor>
            <div class="rounded-[1.5rem] border border-dashed border-slate-200 bg-white p-5 text-sm text-fb-ink-soft">Loading targets...</div>
          </div>
        </div>
      </section>

      <section class="grid gap-6 xl:grid-cols-2">
        <LessonReportForm formId="admin-report-form" />
        <AssessmentForm formId="admin-assessment-form" />
      </section>

      <section class="grid gap-6 xl:grid-cols-[0.95fr_1.05fr]">
        <TargetForm formId="admin-target-form" />
        <ReportTimeline containerId="admin-report-timeline" />
      </section>
    </RoleGuard>
  </DashboardLayout>

  <script>
    import { bootstrapAdminDashboard } from "../lib/admin-dashboard";

    bootstrapAdminDashboard().catch((error) => {
      const target = document.querySelector("[data-role-error-message]");
      if (target instanceof HTMLElement) {
        target.textContent = error instanceof Error ? error.message : "Admin dashboard failed to load.";
      }
    });
  </script>
</BaseLayout>
