---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import FAQList from "../components/FAQList.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { faqs, site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer
    }
  }))
};
---

<BaseLayout
  title="FAQs"
  description="Frequently asked questions about FlyBridge Education, including lessons, pricing, progress tracking and free assessments."
  path="/faqs"
  schema={schema}
>
  <PageHero
    eyebrow="FAQs"
    title="Clear answers for parents before they book."
    body="This page covers the questions families usually ask around lesson delivery, assessments, homework, pricing and ongoing support."
    primaryLabel="Book Free Assessment"
    primaryHref={site.assessmentHref}
    secondaryLabel="Contact FlyBridge"
    secondaryHref={site.contactHref}
  />

  <section class="container-shell section-shell pt-0">
    <div class="mb-6 grid gap-4 md:grid-cols-3">
      <div class="card-panel p-4 sm:p-5">
        <p class="text-xs font-semibold tracking-[0.18em] text-slate-500 uppercase">Before booking</p>
        <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Use this page to answer the practical questions most families ask before the first assessment.</p>
      </div>
      <div class="card-panel p-4 sm:p-5">
        <p class="text-xs font-semibold tracking-[0.18em] text-slate-500 uppercase">Parent clarity</p>
        <p class="mt-2 text-sm leading-6 text-fb-ink-soft">FlyBridge aims to make pricing, progress tracking and communication feel clear rather than vague.</p>
      </div>
      <div class="card-panel p-4 sm:p-5">
        <p class="text-xs font-semibold tracking-[0.18em] text-slate-500 uppercase">Still unsure?</p>
        <p class="mt-2 text-sm leading-6 text-fb-ink-soft">If your situation is more specific, a callback or WhatsApp message is usually the quickest next step.</p>
      </div>
    </div>
    <FAQList items={faqs} />
  </section>

  <CtaBanner
    eyebrow="Still deciding?"
    title="If your question is specific to your child, a callback may be the quickest route."
    body="FlyBridge can talk through year group, confidence, current grades and the sort of support that would be most suitable."
    actions={[
      { label: "Request a Callback", href: site.callbackHref },
      { label: "WhatsApp", href: site.whatsappHref, variant: "secondary" }
    ]}
  />
</BaseLayout>
