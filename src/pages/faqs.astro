---
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQList from "../components/FAQList.astro";
import { faqs, site } from "../data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer
    }
  }))
};
---

<BaseLayout
  title="FAQs"
  description="Frequently asked questions about FlyBridge Education, including lessons, progress tracking, assessments and getting started."
  path="/faqs"
  schema={schema}
>
  <section class="container-shell section-shell-tight">
    <div class="grid gap-5 lg:grid-cols-[1.04fr_0.96fr] lg:items-end">
      <div class="space-y-4">
        <span class="eyebrow">FAQs</span>
        <h1 class="text-balance text-[2rem] font-semibold tracking-tight text-fb-ink sm:text-[2.6rem] lg:text-[3rem]">
          Clear answers before you book.
        </h1>
        <p class="max-w-3xl body-copy-compact">
          These are the questions families most often ask about how tuition works, what the assessment covers and how progress is communicated.
        </p>
      </div>
      <div class="dashboard-list">
        <div class="dashboard-list-item">
          <p class="text-xs font-semibold tracking-[0.16em] text-slate-500 uppercase">Assessment first</p>
          <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Families can discuss suitability, subject focus and likely next steps before lessons begin.</p>
        </div>
        <div class="dashboard-list-item">
          <p class="text-xs font-semibold tracking-[0.16em] text-slate-500 uppercase">Need a specific answer?</p>
          <p class="mt-2 text-sm leading-6 text-fb-ink-soft">If your situation is more specific, a callback or WhatsApp message is usually the fastest route.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell-tight pt-0">
    <FAQList items={faqs} />
  </section>

  <section class="container-shell section-shell-tight pt-0">
    <div class="dark-panel p-5 sm:p-6 lg:p-7">
      <div class="grid gap-4 lg:grid-cols-[1fr_0.92fr] lg:items-center">
        <div>
          <span class="eyebrow border-white/15 bg-white/5 text-sky-100">Still deciding?</span>
          <h2 class="mt-4 text-balance text-[1.8rem] font-semibold tracking-tight text-white sm:text-[2.2rem]">Talk through the right next step for your child.</h2>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          <a class="cta-button justify-center bg-white text-fb-bg hover:bg-sky-50" href={site.callbackHref}>Request a Callback</a>
          <a class="ghost-button justify-center border-white/15 bg-white/5 text-white hover:bg-white/10" href={site.whatsappHref} target="_blank" rel="noreferrer">WhatsApp</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
