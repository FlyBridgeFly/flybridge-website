---
import BaseLayout from "../layouts/BaseLayout.astro";
import PolicyPage from "../components/PolicyPage.astro";
import { site } from "../data/site";
---

<BaseLayout
  title="Privacy Policy"
  description="Privacy policy for FlyBridge Education, including contact details and how personal information is handled."
  path="/privacy"
>
  <PolicyPage
    eyebrow="Privacy"
    title="Privacy Policy"
    updatedLabel="Last updated July 9, 2026"
    note={`If you would like FlyBridge to update or remove information connected to an enquiry, lesson arrangement or portal access request, the quickest route is to email ${site.email}.`}
  >
    <p>
      FlyBridge Education respects your privacy and is committed to protecting the personal information shared by students, parents and guardians.
    </p>
    <div>
      <h2>Information we may collect</h2>
      <p>
        We may collect names, contact details, student year group information, lesson preferences and communication history when you enquire about tuition or contact us for support.
      </p>
    </div>
    <div>
      <h2>How information is used</h2>
      <p>
        Information is used to respond to enquiries, arrange assessments, provide tuition services, share learning resources and maintain communication with families.
      </p>
    </div>
    <div>
      <h2>Data sharing</h2>
      <p>
        Personal information is not sold. It may be shared only with trusted service providers used to deliver lessons and communication, such as Google Classroom or email services, where relevant.
      </p>
    </div>
    <div>
      <h2>Your rights</h2>
      <p>
        You can request access to, correction of, or deletion of your information by contacting {site.email}.
      </p>
    </div>
    <div>
      <h2>Contact</h2>
      <p>
        For privacy-related questions, email <a class="font-medium text-fb-ink" href={`mailto:${site.email}`}>{site.email}</a>.
      </p>
    </div>
  </PolicyPage>
</BaseLayout>
