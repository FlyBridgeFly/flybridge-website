---
import { site } from "../data/site";

interface Props {
  variant?: "default" | "light";
}

const { variant = "default" } = Astro.props;
const logoSrc = variant === "light" ? site.images.logoLight : site.images.logo;
const markSrc = site.images.logoMark;
---

<a href="/" class="inline-flex items-center gap-3" aria-label="FlyBridge Education home">
  <img
    src={markSrc}
    alt=""
    class="h-9 w-9 rounded-xl object-contain sm:hidden"
    loading="eager"
    decoding="async"
  />
  <img
    src={logoSrc}
    alt="FlyBridge Education"
    class="hidden h-9 w-auto object-contain sm:block lg:h-10"
    loading="eager"
    decoding="async"
  />
</a>
