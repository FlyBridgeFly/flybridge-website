---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "./SectionHeading.astro";
import PricingCard from "./PricingCard.astro";
import CtaBanner from "./CtaBanner.astro";
import { examBoards, pricingFeatures, site } from "../data/site";

interface SubjectPageData {
  name: string;
  slug: string;
  navLabel: string;
  summary: string;
  hero: string;
  image: string;
  imageAlt: string;
  coverage: readonly string[];
  structure: readonly string[];
}

interface Props {
  subject: SubjectPageData;
}

const { subject } = Astro.props;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: `${subject.navLabel} Tuition`,
    description: subject.summary,
    url: new URL(`/${subject.slug}`, site.url).toString()
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: `${subject.navLabel} tuition`,
    provider: {
      "@type": "EducationalOrganization",
      name: site.name,
      url: site.url
    },
    areaServed: "United Kingdom",
    description: subject.summary
  }
];
---

<BaseLayout
  title={`${subject.navLabel} Tuition`}
  description={subject.summary}
  path={`/${subject.slug}`}
  schema={schema}
>
  <section class="container-shell pb-6 pt-4 sm:pb-8 sm:pt-6">
    <div class="card-panel hero-glow overflow-hidden p-5 sm:p-7 lg:p-8">
      <div class="grid gap-6 lg:grid-cols-[1fr_0.92fr] lg:items-center lg:gap-8">
        <div class="space-y-4">
          <span class="eyebrow">{subject.navLabel}</span>
          <h1 class="max-w-4xl text-balance text-[2.1rem] font-semibold tracking-tight text-fb-ink sm:text-[2.8rem] lg:text-[3.15rem] lg:leading-[1.04]">{subject.name} tuition with greater clarity, structure and exam confidence.</h1>
          <p class="max-w-2xl body-copy sm:text-base">{subject.hero}</p>
          <div class="grid gap-2 sm:grid-cols-3">
            <span class="mini-chip">Free assessment first</span>
            <span class="mini-chip">Parent reporting included</span>
            <span class="mini-chip">Google Classroom support</span>
          </div>
          <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <a class="cta-button w-full sm:w-auto" href={site.assessmentHref}>Book Free Assessment</a>
            <a class="ghost-button w-full sm:w-auto" href={site.callbackHref}>Request a Callback</a>
          </div>
        </div>
        <div class="image-panel relative">
          <img
            src={subject.image}
            alt={subject.imageAlt}
            class="h-[220px] w-full object-cover sm:h-[280px] lg:h-[320px]"
            loading="eager"
            decoding="async"
          />
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-fb-bg/88 via-fb-bg/30 to-transparent p-4 sm:p-5">
            <div class="max-w-sm rounded-[1.15rem] border border-white/10 bg-fb-bg/78 px-4 py-3.5 text-white backdrop-blur">
              <p class="text-xs font-semibold tracking-[0.2em] text-sky-200 uppercase">Ideal for</p>
              <p class="mt-2 text-sm font-semibold sm:text-base">Students who want stronger understanding, better exam answers and more consistent science performance.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell pt-0">
    <div class="grid gap-6 lg:grid-cols-2">
      <div class="space-y-6">
        <SectionHeading
          eyebrow="What is covered"
          title={`What students cover in GCSE ${subject.name}`}
          body="Lessons are adapted to the student, but support typically includes the topics and exam demands most likely to unlock confident performance."
        />
        <div class="grid gap-4">
          {subject.coverage.map((item) => (
            <div class="card-panel px-5 py-4 text-sm leading-6 text-fb-ink sm:text-base">{item}</div>
          ))}
        </div>
      </div>
      <div class="space-y-6">
        <SectionHeading
          eyebrow="Online structure"
          title="How lessons are taught"
          body="Sessions are designed to feel academically rigorous without becoming overwhelming."
        />
        <div class="grid gap-4">
          {subject.structure.map((item) => (
            <div class="card-panel px-5 py-4 text-sm leading-6 text-fb-ink sm:text-base">{item}</div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell section-shell-tight pt-0">
    <div class="surface-note-sky">
      FlyBridge lessons and homework are organised through Google Classroom, while parent reporting stays visible through the FlyBridge Portal with lesson summaries, assessment progress and next-step guidance.
    </div>
  </section>

  <section class="container-shell section-shell">
    <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
      <div class="space-y-5">
        <SectionHeading
          eyebrow="Exam boards"
          title="Support matched to GCSE specifications"
          body="Teaching can be adapted to the student's course and exam board so revision and question practice stay relevant."
        />
        <div class="grid gap-3 sm:grid-cols-2">
          {examBoards.map((board) => (
            <div class="rounded-[1.15rem] border border-slate-200 bg-white/80 px-4 py-3.5 text-sm font-medium text-fb-ink shadow-sm sm:text-base">
              {board}
            </div>
          ))}
        </div>
        <div class="image-panel mt-4">
          <img
            src={site.images.revisionNotebook}
            alt="A revision notebook visual representing ongoing homework and science revision."
            class="h-[210px] w-full object-cover sm:h-[230px]"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
      <PricingCard
        price="£20"
        ctaLabel="Book Free Assessment"
        ctaHref={site.assessmentHref}
        features={pricingFeatures}
        note="Final tuition fees may vary depending on year group, lesson format and availability."
      />
    </div>
  </section>

  <CtaBanner
    eyebrow="Next step"
    title={`Book a free assessment for GCSE ${subject.name}`}
    body="Start with a relaxed conversation about current performance, target grades and the type of support that would make the biggest difference."
    actions={[
      { label: "Book Free Assessment", href: site.assessmentHref },
      { label: "Request a Callback", href: site.callbackHref, variant: "secondary" }
    ]}
  />
</BaseLayout>
