---
import Logo from "./Logo.astro";
import { headerNavigation, keyStageNavigation, portalNavigation, site } from "../data/site";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
const normalisedPath = currentPath === "/" ? "/" : currentPath.replace(/\/$/, "");
const isHomeActive = normalisedPath === "/";
const activeKeyStages = keyStageNavigation.filter((group) =>
  group.href === normalisedPath || group.items.some((item) => item.href === normalisedPath)
);
const portalRoutePrefixes = ["/login", "/forgot-password", "/change-password", "/reset-password", "/parent-portal", "/tutor", "/admin"];
const isPortalActive =
  portalRoutePrefixes.some((route) => normalisedPath === route) || portalNavigation.some((item) => item.href === normalisedPath);
---

<header class="sticky top-0 z-50 px-3 pt-2 sm:px-5 sm:pt-2.5 lg:px-8">
  <div id="site-header" class="mx-auto w-full max-w-7xl rounded-[1.15rem] border border-transparent px-3 py-2 transition duration-300 sm:px-4 sm:py-2.5">
    <div class="flex items-center justify-between gap-3">
      <div class="shrink-0">
        <Logo />
      </div>
      <nav class="hidden min-w-0 items-center gap-1 lg:flex xl:gap-1.5" aria-label="Primary">
        {headerNavigation.map((item) => (
          <a
            class:list={[
              "nav-link rounded-full px-3 py-2",
              isHomeActive && item.href === "/" && "bg-white text-fb-ink shadow-sm"
            ]}
            aria-current={isHomeActive && item.href === "/" ? "page" : undefined}
            href={item.href}
          >
            {item.label}
          </a>
        ))}
        {keyStageNavigation.map((group) => (
          <details class="group relative" data-header-dropdown>
            <summary
              class:list={[
                "nav-link focus-pill flex cursor-pointer list-none items-center gap-2 rounded-full px-3 py-2",
                activeKeyStages.some((item) => item.label === group.label) && "bg-white text-fb-ink shadow-sm"
              ]}
              aria-haspopup="true"
            >
              {group.label}
              <svg viewBox="0 0 20 20" class="h-4 w-4 transition group-open:rotate-180" fill="none" aria-hidden="true">
                <path d="M5 8L10 13L15 8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </summary>
            <div class="absolute left-1/2 top-[3rem] z-20 w-[min(21rem,calc(100vw-4rem))] -translate-x-1/2 rounded-[1.1rem] border border-white/70 bg-white/[0.97] p-3 shadow-xl shadow-slate-900/10 backdrop-blur-xl">
              <div class="space-y-1">
                {group.items.map((item) => (
                  <a
                    class:list={[
                      "block rounded-[0.9rem] px-3 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-fb-ink",
                      item.href === normalisedPath && "bg-slate-100 text-fb-ink"
                    ]}
                    aria-current={item.href === normalisedPath ? "page" : undefined}
                    href={item.href}
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </div>
          </details>
        ))}
        <details class="group relative" data-header-dropdown>
          <summary
            class:list={[
              "nav-link focus-pill flex cursor-pointer list-none items-center gap-2 rounded-full px-3 py-2",
              isPortalActive && "bg-white text-fb-ink shadow-sm"
            ]}
            aria-haspopup="true"
          >
            Portal
            <svg viewBox="0 0 20 20" class="h-4 w-4 transition group-open:rotate-180" fill="none" aria-hidden="true">
              <path d="M5 8L10 13L15 8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </summary>
          <div class="absolute left-1/2 top-[3rem] z-20 w-72 -translate-x-1/2 rounded-[1.35rem] border border-white/70 bg-white/[0.97] p-3 shadow-xl shadow-slate-900/10 backdrop-blur-xl">
            {portalNavigation.map((item) => (
              <a
                class:list={[
                  "block rounded-[0.95rem] px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-fb-ink",
                  item.href === normalisedPath && "bg-slate-100 text-fb-ink"
                ]}
                aria-current={item.href === normalisedPath ? "page" : undefined}
                href={item.href}
              >
                {item.label}
              </a>
            ))}
          </div>
        </details>
      </nav>
      <div class="flex shrink-0 items-center gap-2">
        <details class="group relative" data-header-dropdown>
          <summary
            class="focus-pill grid h-10 w-10 cursor-pointer list-none place-items-center rounded-full border border-slate-200 bg-white/80 text-fb-ink backdrop-blur"
            aria-label="Open account menu"
          >
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" aria-hidden="true">
              <path d="M12 12C14.7614 12 17 9.76142 17 7C17 4.23858 14.7614 2 12 2C9.23858 2 7 4.23858 7 7C7 9.76142 9.23858 12 12 12Z" stroke="currentColor" stroke-width="1.7"></path>
              <path d="M4.5 21C5.54086 17.7161 8.47243 15.5 12 15.5C15.5276 15.5 18.4591 17.7161 19.5 21" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path>
            </svg>
          </summary>
          <div class="absolute right-0 top-[3rem] z-20 w-[min(16rem,calc(100vw-1rem))] max-w-[calc(100vw-1rem)] rounded-[1.25rem] border border-white/70 bg-white/[0.97] p-3 shadow-xl shadow-slate-900/10 backdrop-blur-xl">
            <div class="space-y-1" data-account-signed-out>
              <a class="block rounded-[0.95rem] px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-fb-ink" href="/login?portal=parent">
                Parent login
              </a>
              <a class="block rounded-[0.95rem] px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-fb-ink" href="/login?portal=tutor">
                Tutor login
              </a>
            </div>
            <div class="hidden space-y-1" data-account-signed-in>
              <a class="block rounded-[0.95rem] px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-fb-ink" data-account-dashboard href="/login">
                Open dashboard
              </a>
              <button class="block w-full rounded-[0.95rem] px-4 py-2.5 text-left text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-fb-ink" data-account-signout type="button">
                Sign out
              </button>
            </div>
          </div>
        </details>
        <a class="cta-button shrink-0 px-3.5 py-2 text-sm sm:px-5 sm:py-2.5" href={site.assessmentHref}>
          <span class="sm:hidden">Book</span>
          <span class="hidden sm:inline">Book Assessment</span>
        </a>
        <details class="group lg:hidden" data-header-dropdown data-mobile-drawer>
          <summary
            class="focus-pill grid h-10 w-10 cursor-pointer list-none place-items-center rounded-full border border-slate-200 bg-white/80 text-fb-ink backdrop-blur"
            aria-label="Open navigation"
          >
            <svg viewBox="0 0 24 24" class="h-5 w-5 group-open:hidden" fill="none" aria-hidden="true">
              <path d="M4 7H20M4 12H20M4 17H20" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
            </svg>
            <svg viewBox="0 0 24 24" class="hidden h-5 w-5 group-open:block" fill="none" aria-hidden="true">
              <path d="M6 6L18 18M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
            </svg>
          </summary>
          <div class="fixed inset-0 z-40 hidden bg-slate-950/28 backdrop-blur-[2px] group-open:block" data-mobile-backdrop></div>
          <nav
            class="fixed inset-y-0 right-0 z-50 hidden w-[min(21rem,100vw)] flex-col overflow-x-hidden overflow-y-auto border-l border-white/70 bg-white/[0.98] p-4 shadow-2xl shadow-slate-900/15 backdrop-blur-xl group-open:flex"
            aria-label="Mobile"
            aria-modal="true"
            role="dialog"
            data-mobile-panel
          >
            <div class="flex items-start justify-between gap-4 border-b border-slate-200 pb-4">
              <div class="min-w-0">
                <p class="text-xs font-semibold tracking-[0.22em] text-slate-500 uppercase">Navigate FlyBridge</p>
                <p class="mt-2 text-sm leading-6 text-fb-ink-soft">Key stages, portal links and booking routes in one place.</p>
              </div>
              <button
                class="grid h-9 w-9 shrink-0 place-items-center rounded-full border border-slate-200 bg-white text-fb-ink"
                data-mobile-close
                type="button"
                aria-label="Close navigation"
              >
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" aria-hidden="true">
                  <path d="M6 6L18 18M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                </svg>
              </button>
            </div>

            <div class="mt-5 grid gap-3">
              <a class="cta-button w-full" href={site.assessmentHref}>Book Assessment</a>
            </div>

            <div class="mt-6 grid gap-1.5">
              {headerNavigation.map((item) => (
                <a
                  class:list={[
                    "rounded-[1rem] px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-fb-ink",
                    isHomeActive && item.href === "/" && "bg-slate-100 text-fb-ink"
                  ]}
                  aria-current={isHomeActive && item.href === "/" ? "page" : undefined}
                  href={item.href}
                >
                  {item.label}
                </a>
              ))}
            </div>

            <div class="mt-6 space-y-3">
              {keyStageNavigation.map((group) => (
                <details class:list={["rounded-[1rem] border border-slate-200 bg-slate-50/80", activeKeyStages.some((item) => item.label === group.label) && "border-sky-100 bg-sky-50/60"]}>
                  <summary class="focus-pill flex cursor-pointer list-none items-center justify-between rounded-[1rem] px-4 py-3 text-sm font-semibold text-fb-ink">
                    {group.label}
                    <svg viewBox="0 0 20 20" class="h-4 w-4 transition" fill="none" aria-hidden="true">
                      <path d="M5 8L10 13L15 8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </summary>
                  <div class="space-y-1 px-3 pb-3">
                    {group.items.map((item) => (
                      <a
                        class:list={[
                          "block rounded-xl px-3 py-2 text-sm text-slate-700 transition hover:bg-slate-100 hover:text-fb-ink",
                          item.href === normalisedPath && "bg-slate-100 text-fb-ink"
                        ]}
                        aria-current={item.href === normalisedPath ? "page" : undefined}
                        href={item.href}
                      >
                        {item.label}
                      </a>
                    ))}
                  </div>
                </details>
              ))}

              <details class:list={["rounded-[1rem] border border-slate-200 bg-slate-50/80", isPortalActive && "border-sky-100 bg-sky-50/60"]}>
                <summary class="focus-pill flex cursor-pointer list-none items-center justify-between rounded-[1rem] px-4 py-3 text-sm font-semibold text-fb-ink">
                  Portal
                  <svg viewBox="0 0 20 20" class="h-4 w-4 transition" fill="none" aria-hidden="true">
                    <path d="M5 8L10 13L15 8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </summary>
                <div class="space-y-1 px-3 pb-3">
                  {portalNavigation.map((item) => (
                    <a
                      class:list={[
                        "block rounded-xl px-3 py-2 text-sm text-slate-700 transition hover:bg-slate-100 hover:text-fb-ink",
                        item.href === normalisedPath && "bg-slate-100 text-fb-ink"
                      ]}
                      aria-current={item.href === normalisedPath ? "page" : undefined}
                      href={item.href}
                    >
                      {item.label}
                    </a>
                  ))}
                </div>
              </details>

              <details class="rounded-[1rem] border border-slate-200 bg-slate-50/80">
                <summary class="focus-pill flex cursor-pointer list-none items-center justify-between rounded-[1rem] px-4 py-3 text-sm font-semibold text-fb-ink">
                  Account
                  <svg viewBox="0 0 20 20" class="h-4 w-4 transition" fill="none" aria-hidden="true">
                    <path d="M5 8L10 13L15 8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </summary>
                <div class="space-y-1 px-3 pb-3" data-account-signed-out>
                  <a class="block rounded-xl px-3 py-2 text-sm text-slate-700 transition hover:bg-slate-100 hover:text-fb-ink" href="/login?portal=parent">
                    Parent login
                  </a>
                  <a class="block rounded-xl px-3 py-2 text-sm text-slate-700 transition hover:bg-slate-100 hover:text-fb-ink" href="/login?portal=tutor">
                    Tutor login
                  </a>
                </div>
                <div class="hidden space-y-1 px-3 pb-3" data-account-signed-in>
                  <a class="block rounded-xl px-3 py-2 text-sm text-slate-700 transition hover:bg-slate-100 hover:text-fb-ink" data-account-dashboard href="/login">
                    Open dashboard
                  </a>
                  <button class="block w-full rounded-xl px-3 py-2 text-left text-sm text-slate-700 transition hover:bg-slate-100 hover:text-fb-ink" data-account-signout type="button">
                    Sign out
                  </button>
                </div>
              </details>
            </div>

            <div class="mt-3 grid gap-2 text-sm">
              <a class="focus-pill rounded-[0.95rem] border border-slate-200 bg-white px-4 py-3 font-medium text-fb-ink transition hover:border-slate-300" href={site.whatsappHref} target="_blank" rel="noreferrer">
                WhatsApp FlyBridge
              </a>
              <a class="focus-pill rounded-[0.95rem] border border-slate-200 bg-white px-4 py-3 font-medium text-fb-ink transition hover:border-slate-300" href={`mailto:${site.email}`}>
                Email FlyBridge
              </a>
            </div>
          </nav>
        </details>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  const header = document.getElementById("site-header");
  const dropdowns = Array.from(document.querySelectorAll("details[data-header-dropdown]"));
  const mobileDrawers = Array.from(document.querySelectorAll("details[data-mobile-drawer]"));
  let lastDrawerTrigger = null;
  const focusableSelector = [
    'a[href]',
    'button:not([disabled])',
    'summary',
    'input:not([disabled])',
    'select:not([disabled])',
    'textarea:not([disabled])',
    '[tabindex]:not([tabindex="-1"])'
  ].join(",");
  const toggleHeader = () => {
    if (!header) return;
    const active = window.scrollY > 18;
    header.classList.toggle("bg-white/75", active);
    header.classList.toggle("backdrop-blur-xl", active);
    header.classList.toggle("border-white/70", active);
    header.classList.toggle("shadow-lg", active);
    header.classList.toggle("shadow-slate-900/10", active);
  };
  toggleHeader();
  window.addEventListener("scroll", toggleHeader, { passive: true });

  dropdowns.forEach((dropdown) => {
    const summary = dropdown.querySelector("summary");
    if (summary instanceof HTMLElement) {
      summary.setAttribute("aria-expanded", String(dropdown.open));
    }
    dropdown.addEventListener("toggle", () => {
      if (summary instanceof HTMLElement) {
        summary.setAttribute("aria-expanded", String(dropdown.open));
      }
      if (dropdown.open) {
        dropdowns.forEach((other) => {
          if (other !== dropdown) other.removeAttribute("open");
        });
        if (dropdown.hasAttribute("data-mobile-drawer") && summary instanceof HTMLElement) {
          lastDrawerTrigger = summary;
          const closeButton = dropdown.querySelector("[data-mobile-close]");
          if (closeButton instanceof HTMLElement) {
            window.requestAnimationFrame(() => closeButton.focus());
          }
        }
      } else if (dropdown.hasAttribute("data-mobile-drawer") && lastDrawerTrigger instanceof HTMLElement) {
        window.requestAnimationFrame(() => lastDrawerTrigger.focus());
      }
      document.body.classList.toggle("menu-open", mobileDrawers.some((drawer) => drawer.open));
    });
    dropdown.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => dropdown.removeAttribute("open"));
    });
  });

  document.querySelectorAll("[data-mobile-close]").forEach((button) => {
    button.addEventListener("click", () => {
      mobileDrawers.forEach((drawer) => drawer.removeAttribute("open"));
      document.body.classList.remove("menu-open");
    });
  });

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Node)) return;
    if (target instanceof HTMLElement && target.hasAttribute("data-mobile-backdrop")) {
      mobileDrawers.forEach((drawer) => drawer.removeAttribute("open"));
      document.body.classList.remove("menu-open");
      return;
    }
    dropdowns.forEach((dropdown) => {
      if (!dropdown.contains(target)) dropdown.removeAttribute("open");
    });
    document.body.classList.toggle("menu-open", mobileDrawers.some((drawer) => drawer.open));
  });

  document.addEventListener("keydown", (event) => {
    const openDrawer = mobileDrawers.find((drawer) => drawer.open);
    if (event.key === "Tab" && openDrawer) {
      const panel = openDrawer.querySelector("[data-mobile-panel]");
      if (!(panel instanceof HTMLElement)) return;
      const focusableElements = Array.from(panel.querySelectorAll(focusableSelector)).filter((node) => {
        return node instanceof HTMLElement && !node.hasAttribute("hidden");
      });
      const first = focusableElements[0];
      const last = focusableElements[focusableElements.length - 1];
      if (!(first instanceof HTMLElement) || !(last instanceof HTMLElement)) return;
      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
      return;
    }
    if (event.key !== "Escape") return;
    dropdowns.forEach((dropdown) => dropdown.removeAttribute("open"));
    document.body.classList.remove("menu-open");
  });
</script>

<script>
  import { createBrowserSupabaseClient } from "../lib/supabase";
  import { fetchProfile, getRoleHome } from "../lib/portal-client";

  const client = createBrowserSupabaseClient();
  const signedOutSections = document.querySelectorAll<HTMLElement>("[data-account-signed-out]");
  const signedInSections = document.querySelectorAll<HTMLElement>("[data-account-signed-in]");
  const dashboardLinks = document.querySelectorAll<HTMLAnchorElement>("[data-account-dashboard]");
  const signOutButtons = document.querySelectorAll<HTMLButtonElement>("[data-account-signout]");

  const toggleAccountState = (signedIn: boolean, href = "/login") => {
    signedOutSections.forEach((node) => node.classList.toggle("hidden", signedIn));
    signedInSections.forEach((node) => node.classList.toggle("hidden", !signedIn));
    dashboardLinks.forEach((link) => {
      link.href = href;
    });
  };

  const syncAccountMenu = async () => {
    const {
      data: { session }
    } = await client.auth.getSession();

    if (!session?.user) {
      toggleAccountState(false);
      return;
    }

    try {
      const profile = await fetchProfile(session.user.id);
      if (!profile?.role) {
        toggleAccountState(false);
        return;
      }
      const href = getRoleHome(profile.role);
      toggleAccountState(true, href);
    } catch {
      toggleAccountState(false);
    }
  };

  signOutButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      window.sessionStorage.removeItem("flybridge-temp-password");
      await client.auth.signOut();
      window.location.href = "/login?reason=signed-out";
    });
  });

  client.auth.onAuthStateChange(() => {
    void syncAccountMenu();
  });

  void syncAccountMenu();
</script>
