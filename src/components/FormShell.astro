---
interface Field {
  label: string;
  name: string;
  type?: "text" | "email" | "tel" | "textarea";
  placeholder: string;
  helper?: string;
  required?: boolean;
  autocomplete?: string;
}

interface Props {
  title: string;
  body: string;
  fields: readonly Field[];
  submitLabel: string;
  helper: string;
  subject?: string;
  recipientEmail?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  trustPoints?: readonly {
    title: string;
    body: string;
  }[];
}

const {
  title,
  body,
  fields,
  submitLabel,
  helper,
  subject = "FlyBridge enquiry",
  recipientEmail,
  secondaryLabel,
  secondaryHref,
  trustPoints = []
} = Astro.props;
---

<div class="form-panel">
  <div class="min-w-0 space-y-3">
    <h2 class="text-xl font-semibold tracking-tight text-fb-ink sm:text-2xl">{title}</h2>
    <p class="max-w-2xl body-copy">{body}</p>
  </div>
  <div class="surface-note mt-4">
    FlyBridge keeps first contact clear and low-pressure. Share the essentials and the next step will stay simple.
  </div>
  {trustPoints.length > 0 && (
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      {trustPoints.map((item) => (
        <div class="rounded-[1rem] border border-slate-200 bg-white px-4 py-3.5">
          <p class="text-xs font-semibold tracking-[0.16em] text-slate-500 uppercase">{item.title}</p>
          <p class="mt-2 text-sm leading-6 text-fb-ink-soft">{item.body}</p>
        </div>
      ))}
    </div>
  )}
  <form
    class="mt-6 space-y-4.5"
    action="#"
    method="post"
    data-form-shell
    data-form-subject={subject}
    data-form-recipient={recipientEmail ?? ""}
  >
    <div class="form-grid-compact mt-0">
      {fields.map((field) =>
        field.type === "textarea" ? (
          <label class="md:col-span-2">
            <span class="label-shell">{field.label}</span>
            <textarea
              class="input-shell min-h-[6rem] resize-y"
              name={field.name}
              placeholder={field.placeholder}
              data-label={field.label}
              required={field.required}
              autocomplete={field.autocomplete}
            ></textarea>
            {field.helper && <span class="helper-shell">{field.helper}</span>}
          </label>
        ) : (
          <label>
            <span class="label-shell">{field.label}</span>
            <input
              class="input-shell"
              type={field.type ?? "text"}
              name={field.name}
              placeholder={field.placeholder}
              data-label={field.label}
              required={field.required}
              autocomplete={field.autocomplete}
            />
            {field.helper && <span class="helper-shell">{field.helper}</span>}
          </label>
        )
      )}
    </div>
    <div class="surface-note-sky">
      {helper}
    </div>
    <p class="status-message hidden" data-form-feedback role="status" aria-live="polite"></p>
    <div class="form-actions mt-0">
      <button class="cta-button w-full sm:w-auto" type="submit">{submitLabel}</button>
      {secondaryLabel && secondaryHref && <a class="ghost-button w-full sm:w-auto" href={secondaryHref}>{secondaryLabel}</a>}
    </div>
  </form>
</div>

<script is:inline>
  document.querySelectorAll("[data-form-shell]").forEach((form) => {
    if (!(form instanceof HTMLFormElement)) return;

    const feedback = form.querySelector("[data-form-feedback]");
    const recipient = form.dataset.formRecipient;
    const subject = form.dataset.formSubject ?? "FlyBridge enquiry";

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      if (!form.reportValidity()) return;

      const lines = Array.from(form.querySelectorAll("input, textarea"))
        .filter((field) => field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement)
        .map((field) => {
          const label = field.dataset.label ?? field.name;
          const value = field.value.trim();
          return value ? `${label}: ${value}` : null;
        })
        .filter(Boolean)
        .join("\n");

      if (!recipient) {
        if (feedback instanceof HTMLElement) {
          feedback.classList.remove("hidden");
          feedback.classList.remove("status-success", "status-info");
          feedback.classList.add("status-error");
          feedback.textContent = "This form is missing a recipient email address.";
        }
        return;
      }

      if (feedback instanceof HTMLElement) {
        feedback.classList.remove("hidden");
        feedback.classList.remove("status-error", "status-success");
        feedback.classList.add("status-info");
        feedback.textContent = "Opening your email app with a pre-filled FlyBridge enquiry draft.";
      }

      const mailto = `mailto:${recipient}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(lines)}`;
      window.location.href = mailto;
    });
  });
</script>
