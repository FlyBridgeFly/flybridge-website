---
interface Props {
  title: string;
  body: string;
}

const { title, body } = Astro.props;
---

<article class="card-panel min-w-0 border-dashed p-4 text-center sm:p-5">
  <h2 class="mt-3 text-lg font-semibold tracking-tight text-fb-ink sm:text-xl">{title}</h2>
  <p class="mt-2 text-sm leading-6 text-fb-ink-soft sm:text-base">{body}</p>
</article>
