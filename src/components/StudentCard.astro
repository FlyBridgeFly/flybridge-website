---
interface Props {
  title: string;
  subtitle?: string;
  meta?: string;
}

const { title, subtitle, meta } = Astro.props;
---

<article class="card-panel min-w-0 p-4 sm:p-5">
  {meta && <p class="text-xs font-semibold tracking-[0.18em] text-slate-500 uppercase">{meta}</p>}
  <h3 class="mt-2 text-lg font-semibold text-fb-ink sm:text-xl">{title}</h3>
  {subtitle && <p class="mt-2 max-w-md text-sm leading-6 text-fb-ink-soft">{subtitle}</p>}
  <slot />
</article>
