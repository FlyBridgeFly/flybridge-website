---
interface Action {
  label: string;
  href: string;
  variant?: "primary" | "secondary";
}

interface Props {
  eyebrow?: string;
  title: string;
  body: string;
  actions: readonly Action[];
}

const { eyebrow, title, body, actions } = Astro.props;
---

<section class="container-shell section-shell">
  <div class="dark-panel relative overflow-hidden p-8 sm:p-10 lg:p-14">
    <div class="absolute inset-y-0 right-0 hidden w-1/2 bg-[radial-gradient(circle_at_top,rgba(77,162,255,0.28),transparent_55%)] lg:block"></div>
    <div class="relative grid gap-10 lg:grid-cols-[1fr_0.95fr] lg:items-center">
      <div class="space-y-5">
        {eyebrow && <span class="eyebrow border-white/15 bg-white/5 text-sky-100">{eyebrow}</span>}
        <h2 class="max-w-2xl text-balance text-3xl font-semibold tracking-tight text-white sm:text-4xl">{title}</h2>
        <p class="max-w-2xl text-lg leading-8 text-slate-300">{body}</p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        {actions.map((action) => (
          <a
            class:list={[
              "inline-flex items-center justify-center rounded-[1.5rem] px-5 py-4 text-sm font-semibold transition duration-300 hover:-translate-y-0.5",
              action.variant === "secondary"
                ? "border border-white/15 bg-white/5 text-white backdrop-blur hover:bg-white/10"
                : "bg-white text-fb-bg hover:bg-sky-50"
            ]}
            href={action.href}
          >
            {action.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
