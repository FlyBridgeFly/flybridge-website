---
interface Props {
  title?: string;
  body?: string;
  containerId: string;
}

const {
  title = "Recent lesson reports",
  body = "The latest lesson reports appear here once tutors begin recording them.",
  containerId
} = Astro.props;
---

<section class="space-y-5">
  <div class="space-y-2">
    <h2 class="text-2xl font-semibold tracking-tight text-fb-ink">{title}</h2>
    <p class="text-sm leading-7 text-fb-ink-soft">{body}</p>
  </div>
  <div class="space-y-4" id={containerId} data-admin-recent-reports>
    <article class="card-panel p-6 text-sm text-fb-ink-soft">Loading recent reports...</article>
  </div>
</section>
