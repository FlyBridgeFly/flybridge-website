---
interface Props {
  title?: string;
  body?: string;
  containerId: string;
}

const {
  title = "Recent lesson reports",
  body = "The latest lesson reports appear here once tutors begin recording them.",
  containerId
} = Astro.props;
---

<section class="space-y-4">
  <div class="dashboard-section-heading">
    <h2 class="text-xl font-semibold tracking-tight text-fb-ink sm:text-2xl">{title}</h2>
    <p class="body-copy">{body}</p>
  </div>
  <div class="dashboard-card-stack" id={containerId} data-admin-recent-reports>
    <article class="card-panel p-4 text-sm text-fb-ink-soft sm:p-5">Loading recent reports...</article>
  </div>
</section>
