---
interface Props {
  eyebrow?: string;
  title: string;
  body: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  tertiaryLabel?: string;
  tertiaryHref?: string;
}

const {
  eyebrow,
  title,
  body,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  tertiaryLabel,
  tertiaryHref
} = Astro.props;
---

<section class="container-shell pb-12 pt-10 sm:pb-16 sm:pt-14">
  <div class="card-panel hero-glow overflow-hidden p-8 sm:p-10 lg:p-14">
    <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div class="space-y-7">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        <div class="space-y-5">
          <h1 class="max-w-4xl text-balance text-5xl font-semibold tracking-tight text-fb-ink sm:text-6xl lg:text-7xl">{title}</h1>
          <p class="max-w-2xl text-lg leading-8 text-fb-ink-soft sm:text-xl">{body}</p>
        </div>
        <div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap">
          <a class="cta-button" href={primaryHref}>{primaryLabel}</a>
          {secondaryLabel && secondaryHref && <a class="ghost-button" href={secondaryHref}>{secondaryLabel}</a>}
          {tertiaryLabel && tertiaryHref && <a class="ghost-button" href={tertiaryHref}>{tertiaryLabel}</a>}
        </div>
      </div>
      <div class="relative min-h-[320px]">
        <div class="absolute left-8 top-8 h-36 w-36 rounded-full bg-sky-200/70 blur-3xl"></div>
        <div class="absolute right-10 top-6 h-24 w-24 rounded-full border border-white/80 bg-white/70 shadow-lg animate-float"></div>
        <div class="absolute left-0 top-20 w-full rounded-[2rem] border border-white/75 bg-white/[0.86] p-6 shadow-fb backdrop-blur-xl">
          <div class="grid gap-5">
            <div class="flex items-center justify-between rounded-[1.5rem] bg-fb-bg px-5 py-4 text-white shadow-lg shadow-slate-900/15">
              <div>
                <p class="text-xs font-semibold tracking-[0.2em] text-sky-200 uppercase">Parent confidence</p>
                <p class="mt-2 text-lg font-semibold">Clear plans. Calm teaching. Measurable progress.</p>
              </div>
            </div>
            <div class="grid gap-5 sm:grid-cols-2">
              <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-5">
                <p class="text-xs font-semibold tracking-[0.2em] text-slate-500 uppercase">Assessment</p>
                <p class="mt-3 text-lg font-semibold text-fb-ink">Understand the gap before lessons begin</p>
              </div>
              <div class="rounded-[1.5rem] border border-slate-200 bg-white p-5 animate-float-slow">
                <p class="text-xs font-semibold tracking-[0.2em] text-slate-500 uppercase">Tracking</p>
                <p class="mt-3 text-lg font-semibold text-fb-ink">Homework, resources and feedback in one place</p>
              </div>
            </div>
            <div class="rounded-[1.75rem] border border-slate-200 bg-white p-5">
              <svg viewBox="0 0 320 120" class="w-full" fill="none" aria-hidden="true">
                <path d="M28 83C46 70 69 42 95 42C121 42 127 86 159 86C191 86 206 31 239 31C261 31 277 43 292 55" stroke="#4DA2FF" stroke-width="6" stroke-linecap="round"></path>
                <circle cx="95" cy="42" r="7" fill="#9DD0FF"></circle>
                <circle cx="159" cy="86" r="7" fill="#9DD0FF"></circle>
                <circle cx="239" cy="31" r="7" fill="#9DD0FF"></circle>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
