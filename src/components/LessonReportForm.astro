---
interface Props {
  formId: string;
  title?: string;
}

const { formId, title = "Create lesson report" } = Astro.props;
---

<form id={formId} class="form-panel" data-lesson-report-form>
  <div class="form-heading">
    <h2 class="text-xl font-semibold tracking-tight text-fb-ink sm:text-2xl">{title}</h2>
    <p class="body-copy">Capture the lesson quickly so parents get a useful update without extra admin overhead.</p>
  </div>
  <div class="surface-note-sky mt-4">
    Keep each update short, specific and parent-friendly. One strong sentence per field is usually enough.
  </div>
  <div class="mt-4 flex flex-wrap gap-2">
    <span class="mini-chip">Fast to complete</span>
    <span class="mini-chip">Parent-visible summary</span>
    <span class="mini-chip">Next step included</span>
  </div>
  <div class="form-grid-compact">
    <label>
      <span class="label-shell">Student</span>
      <select class="input-shell" name="student-id" data-student-select required></select>
      <span class="helper-shell">Only students already linked to your dashboard will appear here.</span>
    </label>
    <label>
      <span class="label-shell">Lesson date</span>
      <input class="input-shell" name="lesson-date" type="date" required />
      <span class="helper-shell">Use the date the teaching took place so the portal timeline stays clear for families.</span>
    </label>
    <label class="sm:col-span-2">
      <span class="label-shell">Topic covered</span>
      <input class="input-shell" name="topic" type="text" placeholder="For example: Bonding and structure" required />
      <span class="helper-shell">Use the main topic or question focus so parents can recognise what the lesson covered.</span>
    </label>
    <label class="sm:col-span-2">
      <span class="label-shell">Quick lesson summary</span>
      <textarea class="input-shell min-h-[5.5rem] resize-y" name="summary" placeholder="What was covered and how did the student respond?" required></textarea>
      <span class="helper-shell">Keep this practical: what was taught, how the student engaged, and what felt more secure by the end.</span>
    </label>
    <label>
      <span class="label-shell">Strengths noticed</span>
      <textarea class="input-shell min-h-[4.5rem] resize-y" name="strengths" placeholder="Confidence, recall, exam technique, etc."></textarea>
      <span class="helper-shell">Optional, but helpful when you want parents to see what is becoming more secure.</span>
    </label>
    <label>
      <span class="label-shell">Homework / next step</span>
      <textarea class="input-shell min-h-[4.5rem] resize-y" name="homework" placeholder="Tasks to complete before the next lesson"></textarea>
      <span class="helper-shell">Optional if there is no set task, but useful whenever follow-up work has been agreed.</span>
    </label>
    <label class="sm:col-span-2">
      <span class="label-shell">Areas to improve / next teaching focus</span>
      <textarea class="input-shell min-h-[4.5rem] resize-y" name="next-steps" placeholder="What should happen next in the tuition plan?"></textarea>
      <span class="helper-shell">Use this for the clearest focus area so parents understand what FlyBridge is working on next.</span>
    </label>
  </div>
  <p class="status-message mt-4 hidden" data-form-status role="status" aria-live="polite"></p>
  <div class="form-actions">
    <button class="cta-button w-full sm:w-auto" type="submit">Save lesson report</button>
  </div>
</form>
