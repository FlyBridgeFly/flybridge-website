---
interface Props {
  formId: string;
  title?: string;
}

const { formId, title = "Add assessment" } = Astro.props;
---

<form id={formId} class="form-panel" data-assessment-form>
  <div class="form-heading">
    <h2 class="text-xl font-semibold tracking-tight text-fb-ink sm:text-2xl">{title}</h2>
    <p class="body-copy-compact">Add the latest checkpoint and enough context for a parent to understand it quickly.</p>
  </div>
  <div class="form-grid-compact">
    <label>
      <span class="label-shell">Student</span>
      <select class="input-shell" name="student-id" data-student-select required></select>
      <span class="helper-shell">Choose the student first so the assessment is attached to the correct reporting history.</span>
    </label>
    <label>
      <span class="label-shell">Assessment date</span>
      <input class="input-shell" name="assessment-date" type="date" required />
      <span class="helper-shell">Use the date the checkpoint was set or reviewed with the student.</span>
    </label>
    <label class="sm:col-span-2">
      <span class="label-shell">Assessment title</span>
      <input class="input-shell" name="title" type="text" placeholder="For example: Chemistry retrieval quiz" required />
    </label>
    <label>
      <span class="label-shell">Score</span>
      <input class="input-shell" name="score" type="number" min="0" step="0.1" placeholder="14" />
      <span class="helper-shell">Leave blank only if the checkpoint was discussed qualitatively rather than marked numerically.</span>
    </label>
    <label>
      <span class="label-shell">Maximum score</span>
      <input class="input-shell" name="max-score" type="number" min="0" step="0.1" placeholder="20" />
      <span class="helper-shell">Adding the maximum score helps the parent portal show the result more clearly.</span>
    </label>
    <label class="sm:col-span-2">
      <span class="label-shell">Notes</span>
      <textarea class="input-shell min-h-[4.5rem] resize-y" name="notes" placeholder="Optional notes for context or interpretation"></textarea>
      <span class="helper-shell">Use a short note only if the score needs explanation.</span>
    </label>
  </div>
  <p class="status-message mt-4 hidden" data-form-status role="status" aria-live="polite"></p>
  <div class="form-actions">
    <button class="cta-button w-full sm:w-auto" type="submit">Save assessment</button>
  </div>
</form>
