---
import { site } from "../data/site";

interface Props {
  title: string;
  description: string;
  active: "admin" | "tutor" | "parent";
}

const { title, description, active } = Astro.props;

const navItems = [
  { label: "Admin", href: "/admin", key: "admin" },
  { label: "Tutor", href: "/tutor", key: "tutor" },
  { label: "Parent Portal", href: "/parent-portal", key: "parent" }
] as const;
---

<section class="container-shell pb-7 pt-3 sm:pb-9 sm:pt-4">
  <div class="grid gap-4 xl:grid-cols-[280px_1fr] xl:gap-5">
    <aside class="card-panel h-fit p-4 sm:p-5 xl:sticky xl:top-24">
      <div class="grid gap-3.5 lg:grid-cols-[1.04fr_0.96fr] xl:grid-cols-1">
        <div class="min-w-0">
          <p class="text-xs font-semibold tracking-[0.22em] text-slate-500 uppercase">FlyBridge reporting</p>
          <h1 class="mt-2 text-[1.42rem] font-semibold tracking-tight text-fb-ink sm:text-[1.62rem]">{title}</h1>
          <p class="mt-2 body-copy-compact">{description}</p>
        </div>

        <div class="rounded-[1.05rem] border border-slate-200 bg-slate-50/85 p-4">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <p class="text-xs font-semibold tracking-[0.18em] text-slate-500 uppercase">Signed in as</p>
              <p class="mt-2 text-base font-semibold text-fb-ink" data-session-name>Loading...</p>
              <p class="mt-1 break-words text-sm text-fb-ink-soft" data-session-email></p>
            </div>
            <span class="inline-flex rounded-full bg-white px-3 py-1 text-[11px] font-semibold tracking-[0.16em] text-slate-500 uppercase" data-session-role>
              Checking access
            </span>
          </div>
        </div>
      </div>

      <div class="dashboard-divider mt-4">
        <nav class="dashboard-nav-scroll snap-x" aria-label="Portal">
          {navItems.map((item) => (
            <a
              class:list={[
                "focus-pill min-w-max snap-start rounded-[0.95rem] px-4 py-2.5 text-sm font-semibold transition text-center xl:min-w-0 xl:text-left",
                active === item.key
                  ? "bg-fb-bg text-white"
                  : "border border-slate-200 bg-white text-fb-ink hover:border-slate-300"
              ]}
              aria-current={active === item.key ? "page" : undefined}
              href={item.href}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>

      <div class="dashboard-divider mt-4">
        <div class="surface-note">
          Portal access is matched to your FlyBridge role, so each dashboard stays focused and uncluttered.
        </div>
      </div>

      <div class="mt-4 flex flex-col gap-2.5 sm:flex-row xl:flex-col">
        <a class="ghost-button justify-center xl:justify-start" href={site.contactHref}>Contact FlyBridge</a>
        <button class="cta-button justify-center xl:justify-start" data-logout type="button">Sign out</button>
      </div>
    </aside>

    <div class="dashboard-shell">
      <slot />
    </div>
  </div>
</section>
