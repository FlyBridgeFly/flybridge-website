---
import SubjectIcon from "./SubjectIcon.astro";

interface Props {
  subject: {
    name: string;
    navLabel: string;
    slug: string;
    summary: string;
  };
}

const { subject } = Astro.props;
---

<article class="card-panel p-5 transition duration-300 hover:-translate-y-1 sm:p-6">
  <div class="flex items-start gap-4">
    <SubjectIcon subject={subject.name} />
    <div class="min-w-0">
      <h3 class="text-lg font-semibold text-fb-ink sm:text-xl">{subject.navLabel}</h3>
      <p class="mt-2 text-sm leading-6 text-fb-ink-soft sm:text-base sm:leading-7">{subject.summary}</p>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="mini-chip">Free assessment</span>
        <span class="mini-chip">Parent reporting</span>
      </div>
      <a class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-fb-ink underline decoration-slate-300 underline-offset-4 transition hover:decoration-fb-ink" href={`/${subject.slug}`}>
        Explore subject
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</article>
