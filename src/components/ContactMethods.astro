---
import { site } from "../data/site";

interface Method {
  label: string;
  value: string;
  href: string;
  hint?: string;
}

interface Props {
  methods?: readonly Method[];
}

const defaultMethods = [
  {
    label: "WhatsApp",
    value: site.phone,
    href: site.whatsappHref,
    hint: "Fastest route for quick questions"
  },
  {
    label: "Email",
    value: site.email,
    href: `mailto:${site.email}`,
    hint: "Best for fuller context or attachments"
  },
  {
    label: "Google Classroom",
    value: "Open lesson hub",
    href: site.classroomHref,
    hint: "Student lessons, homework and resources"
  }
] as const satisfies readonly Method[];

const { methods = defaultMethods } = Astro.props;
---

<div class="grid gap-3 md:grid-cols-2 xl:grid-cols-3">
  {methods.map((method) => (
    <a
      class="card-panel focus-pill flex h-full min-w-0 flex-col justify-between p-4 transition duration-300 hover:-translate-y-1 sm:p-5"
      href={method.href}
      target={method.href.startsWith("http") ? "_blank" : undefined}
      rel={method.href.startsWith("http") ? "noreferrer" : undefined}
    >
      <p class="text-xs font-semibold tracking-[0.22em] text-slate-500 uppercase">{method.label}</p>
      <p class="mt-2 text-base font-semibold text-fb-ink break-words sm:text-lg">{method.value}</p>
      {method.hint && <p class="mt-3 text-sm leading-6 text-fb-ink-soft">{method.hint}</p>}
    </a>
  ))}
</div>
