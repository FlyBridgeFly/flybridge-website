---
import { site } from "../data/site";

const methods = [
  {
    label: "WhatsApp",
    value: site.phone,
    href: site.whatsappHref
  },
  {
    label: "Email",
    value: site.email,
    href: `mailto:${site.email}`
  },
  {
    label: "Student Hub",
    value: "Open Google Classroom",
    href: "/student-hub"
  }
] as const;
---

<div class="grid gap-4 sm:grid-cols-3">
  {methods.map((method) => (
    <a class="card-panel p-6 transition duration-300 hover:-translate-y-1" href={method.href}>
      <p class="text-xs font-semibold tracking-[0.22em] text-slate-500 uppercase">{method.label}</p>
      <p class="mt-3 text-lg font-semibold text-fb-ink">{method.value}</p>
    </a>
  ))}
</div>
