---
interface Props {
  formId: string;
  title?: string;
}

const { formId, title = "Add or update target" } = Astro.props;
---

<form id={formId} class="card-panel p-7" data-target-form>
  <input name="target-id" type="hidden" value="" />
  <div class="space-y-3">
    <h2 class="text-2xl font-semibold tracking-tight text-fb-ink">{title}</h2>
    <p class="text-sm leading-7 text-fb-ink-soft">Use this form for new targets or to update an existing one after selecting it from the current target list.</p>
  </div>
  <div class="mt-6 grid gap-5 sm:grid-cols-2">
    <label>
      <span class="label-shell">Student</span>
      <select class="input-shell" name="student-id" data-student-select></select>
    </label>
    <label>
      <span class="label-shell">Status</span>
      <select class="input-shell" name="status">
        <option value="open">Open</option>
        <option value="in progress">In progress</option>
        <option value="complete">Complete</option>
      </select>
    </label>
    <label class="sm:col-span-2">
      <span class="label-shell">Target title</span>
      <input class="input-shell" name="title" type="text" placeholder="For example: Improve six-mark biology responses" />
    </label>
    <label>
      <span class="label-shell">Target date</span>
      <input class="input-shell" name="due-date" type="date" />
    </label>
    <label class="sm:col-span-2">
      <span class="label-shell">Notes</span>
      <textarea class="input-shell min-h-24 resize-y" name="notes" placeholder="Explain the focus and what success will look like"></textarea>
    </label>
  </div>
  <p class="mt-5 hidden text-sm font-medium" data-form-status></p>
  <button class="cta-button mt-6" type="submit">Save target</button>
</form>
