---
import { site } from "../data/site";
---

<footer class="mt-24 bg-fb-bg text-fb-text">
  <div class="container-shell grid gap-12 py-16 lg:grid-cols-[1.2fr_0.8fr]">
    <div class="space-y-4">
      <p class="text-lg font-semibold">{site.name}</p>
      <p class="max-w-md text-sm leading-7 text-slate-300">{site.tagline}</p>
      <div class="flex flex-wrap gap-4 text-sm text-slate-300">
        <a class="footer-link" href={`mailto:${site.email}`}>{site.email}</a>
        <a class="footer-link" href={site.whatsappHref}>{site.phone}</a>
      </div>
    </div>
    <div class="grid gap-8 sm:grid-cols-2">
      <div class="space-y-4">
        <p class="text-xs font-semibold tracking-[0.22em] text-slate-400 uppercase">Quick links</p>
        <div class="flex flex-col gap-3">
          <a class="footer-link" href="/">Home</a>
          <a class="footer-link" href="/privacy">Privacy</a>
          <a class="footer-link" href="/terms">Terms</a>
          <a class="footer-link" href="/student-hub">Student Hub</a>
        </div>
      </div>
      <div class="space-y-4">
        <p class="text-xs font-semibold tracking-[0.22em] text-slate-400 uppercase">Contact</p>
        <div class="flex flex-col gap-3">
          <a class="footer-link" href="/#contact">Book Assessment</a>
          <a class="footer-link" href={site.whatsappHref}>WhatsApp</a>
          <a class="footer-link" href={`mailto:${site.email}`}>Email</a>
        </div>
      </div>
    </div>
  </div>
</footer>
