---
import Logo from "./Logo.astro";
import { footerQuickLinks, footerSupportLinks, site, subjectNavigation } from "../data/site";
---

<footer class="mt-24 bg-fb-bg text-fb-text">
  <div class="container-shell grid gap-12 py-16 lg:grid-cols-[1.05fr_0.95fr_0.8fr]">
    <div class="space-y-4">
      <Logo variant="light" />
      <p class="max-w-md text-sm leading-7 text-slate-300">{site.tagline}</p>
      <div class="flex flex-wrap gap-4 text-sm text-slate-300">
        <a class="footer-link" href={`mailto:${site.email}`}>{site.email}</a>
        <a class="footer-link" href={site.whatsappHref} target="_blank" rel="noreferrer">{site.phone}</a>
      </div>
    </div>
    <div class="grid gap-8 sm:grid-cols-2">
      <div class="space-y-4">
        <p class="text-xs font-semibold tracking-[0.22em] text-slate-400 uppercase">Quick links</p>
        <div class="flex flex-col gap-3">
          {footerQuickLinks.map((item) => (
            <a class="footer-link" href={item.href}>{item.label}</a>
          ))}
        </div>
      </div>
      <div class="space-y-4">
        <p class="text-xs font-semibold tracking-[0.22em] text-slate-400 uppercase">Subjects</p>
        <div class="flex flex-col gap-3">
          {subjectNavigation.map((item) => (
            <a class="footer-link" href={item.href}>{item.label}</a>
          ))}
        </div>
      </div>
    </div>
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-1">
      <div class="space-y-4">
        <p class="text-xs font-semibold tracking-[0.22em] text-slate-400 uppercase">Support</p>
        <div class="flex flex-col gap-3">
          {footerSupportLinks.map((item) => (
            <a class="footer-link" href={item.href}>{item.label}</a>
          ))}
        </div>
      </div>
      <div class="space-y-4">
        <p class="text-xs font-semibold tracking-[0.22em] text-slate-400 uppercase">Contact</p>
        <div class="flex flex-col gap-3">
          <a class="footer-link" href={site.whatsappHref} target="_blank" rel="noreferrer">WhatsApp</a>
          <a class="footer-link" href={`mailto:${site.email}`}>Email</a>
          <a class="footer-link" href={site.contactHref}>Contact Page</a>
        </div>
      </div>
    </div>
  </div>
</footer>
