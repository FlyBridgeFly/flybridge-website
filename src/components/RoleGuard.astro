---
interface Props {
  title?: string;
  body?: string;
}

const {
  title = "Checking access",
  body = "We are confirming your account details and portal permissions."
} = Astro.props;
---

<div class="space-y-8">
  <div class="card-panel p-8 text-center" data-role-loading>
    <h2 class="text-2xl font-semibold text-fb-ink">{title}</h2>
    <p class="mt-3 text-base leading-7 text-fb-ink-soft">{body}</p>
  </div>
  <div class="hidden" data-role-error>
    <article class="card-panel border border-rose-100 bg-rose-50/70 p-8">
      <h2 class="text-2xl font-semibold text-fb-ink">Access required</h2>
      <p class="mt-3 text-base leading-7 text-rose-700" data-role-error-message></p>
    </article>
  </div>
  <div class="hidden space-y-8" data-role-guard>
    <slot />
  </div>
</div>
